# =============================================================================
# PERPLEXICA - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - perplexica: openai_api_key
#
# NOTE: Perplexica reads its config from a separate config file
# (typically config.toml or .env in the data volume), not from
# compose.yaml environment variables. The OPENAI_API_KEY and other
# search provider keys should be set in that config file or mounted
# as a volume. This secrets.env supports any future compose-level vars.
# =============================================================================
OPENAI_API_KEY={{ infisical:///openai_api_key }}