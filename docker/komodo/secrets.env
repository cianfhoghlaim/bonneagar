# =============================================================================
# KOMODO CORE - Locket Secrets Template
# =============================================================================
# Resolved by Locket at runtime via 1Password Connect
# Vault: dev-baile

# Database credentials
KOMODO_DATABASE_USERNAME={{ op://dev-baile/komodo/database_username }}
KOMODO_DATABASE_PASSWORD={{ op://dev-baile/komodo/database_password }}

# Security secrets
KOMODO_JWT_SECRET={{ op://dev-baile/komodo/jwt-secret }}
KOMODO_PASSKEY={{ op://dev-baile/komodo/passkey }}
KOMODO_WEBHOOK_SECRET={{ op://dev-baile/komodo/webhook-secret }}

# Admin initialization
KOMODO_INIT_ADMIN_USERNAME={{ op://dev-baile/komodo/username }}
KOMODO_INIT_ADMIN_PASSWORD={{ op://dev-baile/komodo/password }}

# OIDC Authentication (PocketID)
KOMODO_OIDC_ENABLED=true
KOMODO_OIDC_PROVIDER=https://auth.cianfhoghlaim.ie
KOMODO_OIDC_CLIENT_ID={{ op://dev-baile/komodo-oidc/client_id }}
KOMODO_OIDC_CLIENT_SECRET={{ op://dev-baile/komodo-oidc/client_secret }}
