# =============================================================================
# OLM Oracle - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
#
# PREREQUISITES:
#   1. Create OLM site "arm1-oci-olm" in Pangolin UI (Sites -> Create Site -> OLM)
#   2. Copy the ID and Secret from the site creation dialog
#   3. Create Infisical secret:
#      op item create --vault dev-baile --title "arm1-oci-olm" \
#        id="<olm_id>" secret="<olm_secret>"
#
# USAGE:
#   docker compose -f compose.yaml -f sidecar.yaml up -d
# =============================================================================

# OLM Credentials (from Pangolin site creation)
OLM_ID={{ infisical:///id }}
OLM_SECRET={{ infisical:///secret }}
