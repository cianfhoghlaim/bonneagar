# PostgreSQL
LAKEKEEPER_DB_USERNAME={{ infisical:///username }}
LAKEKEEPER_DB_PASSWORD={{ infisical:///password }}

# Encryption
LAKEKEEPER_ENCRYPTION_KEY={{ infisical:///encryption_key }}

# MinIO
MINIO_ROOT_USER={{ infisical:///username }}
MINIO_ROOT_PASSWORD={{ infisical:///password }}
