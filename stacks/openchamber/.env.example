# =============================================================================
# OPENCHAMBER — Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local
# Then: docker compose -f compose.yaml -f sidecar.yaml up -d
#
# All values that resolve to "infisical://dev-baile/..." URIs are populated
# at runtime by the Locket sidecar. Only put non-secret defaults here.
# =============================================================================

# =============================================================================
# UI
# =============================================================================
OPENCHAMBER_PORT=3000
OPENCHAMBER_THEME=cianchoghlaim-dark
OPENCHAMBER_LOG_LEVEL=info

# =============================================================================
# Public hostname (used by pangolin.yaml blueprint)
# =============================================================================
PANGOLIN_DOMAIN=openchamber.cianfhoghlaim.ie

# =============================================================================
# Future enhancements (uncomment to enable)
# =============================================================================
# External OpenCode mode (point at a separately-running OpenCode daemon):
# OPENCODE_HOST=http://opencode-daemon:4096
#
# Cloudflare tunnel mode (bypass Pangolin, expose publicly):
# OPENCHAMBER_TUNNEL_TOKEN=eyJhIjoixxxxxxxxxxxxxxxxxxxxxxxx