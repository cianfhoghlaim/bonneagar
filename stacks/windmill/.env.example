# =============================================================================
# WINDMILL - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# Windmill Image
# =============================================================================
WM_IMAGE=ghcr.io/windmill-labs/windmill:latest

# =============================================================================
# PostgreSQL Database (non-secret defaults for local dev)
# =============================================================================
POSTGRES_PASSWORD=changeme
POSTGRES_DB=windmill

# =============================================================================
# Connection URL (uses compose-internal DNS for local dev)
# =============================================================================
DATABASE_URL=postgresql://postgres:changeme@db:5432/windmill

# =============================================================================
# Logging
# =============================================================================
LOG_MAX_SIZE=20m
LOG_MAX_FILE=10

# =============================================================================
# Secrets (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# POSTGRES_PASSWORD=<strong-password>         # Set via Locket/Infisical in production
# DATABASE_URL=postgresql://postgres:<password>@db:5432/windmill  # Set via Locket/Infisical in production