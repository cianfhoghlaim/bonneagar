# =============================================================================
# OLAKE-UI - Locket Secrets Template
# =============================================================================
# Used with: locket exec --env-file secrets.env -- docker compose up -d
# =============================================================================

# Encryption key (AES-256 or AWS KMS ARN)
OLAKE_SECRET_KEY={{ infisical:///secret_key }}

# Admin user credentials
OLAKE_ADMIN_USERNAME={{ infisical:///admin_username }}
OLAKE_ADMIN_PASSWORD={{ infisical:///admin_password }}
OLAKE_ADMIN_EMAIL={{ infisical:///admin_email }}

# Temporal PostgreSQL
OLAKE_DB_USER={{ infisical:///username }}
OLAKE_DB_PASSWORD={{ infisical:///password }}
