# =============================================================================
# CAL-DIY — Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   calcom/         database_url, postgres_password, nextauth_secret,
#                   encryption_key, webhook_secret, cron_api_key
#   team-mailbox/   imap_user, smtp_password, from_email
# =============================================================================

# Database
CALCOM_DATABASE_URL={{ infisical:///calcom/database_url }}
CALCOM_POSTGRES_PASSWORD={{ infisical:///calcom/postgres_password }}

# Auth + encryption
CALCOM_NEXTAUTH_SECRET={{ infisical:///calcom/nextauth_secret }}
CALCOM_ENCRYPTION_KEY={{ infisical:///calcom/encryption_key }}

# Webhooks
CALCOM_WEBHOOK_SECRET={{ infisical:///calcom/webhook_secret }}
CALCOM_CRON_API_KEY={{ infisical:///calcom/cron_api_key }}

# Outbound mail (reuses team-mailbox)
TEAM_IMAP_USER={{ infisical:///team-mailbox/imap_user }}
TEAM_SMTP_PASSWORD={{ infisical:///team-mailbox/smtp_password }}
TEAM_FROM_EMAIL={{ infisical:///team-mailbox/from_email }}
