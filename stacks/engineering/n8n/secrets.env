# =============================================================================
# N8N — Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
# Every non-public value is an `infisical:///key` reference (Locket short form).
#
# LOCKET USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml -f sidecar.yaml up -d
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   n8n/         encryption_key, jwt_secret, postgres_password, webhook_secret, api_key
# =============================================================================

# Core
N8N_ENCRYPTION_KEY={{ infisical:///n8n/encryption_key }}
N8N_USER_MANAGEMENT_JWT_SECRET={{ infisical:///n8n/jwt_secret }}
N8N_DB_POSTGRES_PASSWORD={{ infisical:///n8n/postgres_password }}
N8N_WEBHOOK_SECRET={{ infisical:///n8n/webhook_secret }}

# n8n REST API key (used by n8n-init to import workflows)
N8N_API_KEY={{ infisical:///n8n/api_key }}

# LLM backbone — OpenCode Go (per Go.md)
OPENAI_API_KEY={{ infisical:///openai/api_key }}
OPENAI_BASE_URL={{ infisical:///opencode/openai_base_url }}
