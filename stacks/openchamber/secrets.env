# =============================================================================
# OPENCHAMBER — Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile/openchamber/ (4 total):
#   ui_password          — UI access password (random 32-char hex)
#   openai_api_key       — LITELLM_MASTER_KEY (re-keyed at the Infisical layer)
#   openai_base_url      — http://litellm:4000/v1
#   otel_exporter_otlp_endpoint — Langfuse OTLP/HTTP endpoint
# =============================================================================

# UI access password (2nd-factor auth inside the bundled OpenCode UI)
OPENCHAMBER_UI_PASSWORD={{ infisical:///openchamber/ui_password }}

# LLM provider — LiteLLM chokepoint (M3 plan)
OPENAI_API_KEY={{ infisical:///openchamber/openai_api_key }}
OPENAI_BASE_URL={{ infisical:///openchamber/openai_base_url }}

# Observability — Langfuse OTLP/HTTP
OTEL_EXPORTER_OTLP_ENDPOINT={{ infisical:///openchamber/otel_exporter_otlp_endpoint }}
