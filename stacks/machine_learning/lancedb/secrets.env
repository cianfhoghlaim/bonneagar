# =============================================================================
# LANCEDB - Locket Secrets Template (dev-baile vault)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
# =============================================================================

# S3/R2 Credentials (for self-hosted storage profile)
AWS_ACCESS_KEY_ID=infisical://dev-baile/cloudflare/r2_access_key
AWS_SECRET_ACCESS_KEY=infisical://dev-baile/cloudflare/r2_secret_key
AWS_ENDPOINT_URL=infisical://dev-baile/cloudflare/r2_endpoint

# LanceDB Cloud (optional)
LANCEDB_API_KEY=infisical://dev-baile/lancedb/api_key
LANCEDB_REGION=us-east-1
LANCEDB_USE_CLOUD=false
