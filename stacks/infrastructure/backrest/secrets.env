# =============================================================================
# BACKREST - Locket Secrets Template
# =============================================================================
# Restic repo password (encrypts all backups) + Garage S3 credentials.
# =============================================================================

RESTIC_REPO_PASSWORD={{ infisical://dev-baile/backrest/restic_repo_password }}
AWS_ACCESS_KEY_ID={{ infisical://dev-baile/lakehouse-garage/access_key_id }}
AWS_SECRET_ACCESS_KEY={{ infisical://dev-baile/lakehouse-garage/secret_access_key }}
GARAGE_S3_ENDPOINT=http://lakehouse-garage:3900
