# =============================================================================
# PANGOLIN STACK — Locket secrets template
# =============================================================================
# Placeholders use Infisical's URI scheme per locket docs:
#   infisical:///<secret-name>?env=<env>&path=<folder>&project_id=<uuid>
# Or, with the project_id + env defaults set in compose, simply:
#   infisical:///<secret-name>?path=<folder>
#
# Locket resolves these to real values from the Infisical vault and writes
# the rendered file to /run/secrets/locket/secrets.env inside the container.
# =============================================================================

# Pangolin server secret (used to sign session tokens + cookies)
SERVER_SECRET={{ infisical:///server_secret?path=/pangolin }}

# PocketID encryption key (auto-generated on first deploy via Pangolin UI)
POCKETID_ENCRYPTION_KEY={{ infisical:///encryption_key?path=/pocketid }}

# Postgres credentials
POSTGRES_PASSWORD={{ infisical:///postgres_password?path=/pangolin }}
