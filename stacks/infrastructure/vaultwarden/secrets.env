# =============================================================================
# VAULTWARDEN - Locket Secrets Template
# =============================================================================
# Admin token (generated on first boot, store here for vault rotation).
# PocketID OIDC SSO (optional).
# =============================================================================

VAULTWARDEN_ADMIN_TOKEN={{ infisical://dev-baile/vaultwarden/admin_token }}
VAULTWARDEN_SMTP_PASSWORD={{ infisical://dev-baile/vaultwarden/smtp_password }}

# OIDC SSO via PocketID
SSO_OIDC_CLIENT_ID={{ infisical://dev-baile/pocketid-vaultwarden/client_id }}
SSO_OIDC_CLIENT_SECRET={{ infisical://dev-baile/pocketid-vaultwarden/client_secret }}
SSO_OIDC_AUTHORITY=https://auth.cianfhoghlaim.ie/oidc
SSO_OIDC_SCOPES=openid profile email
SSO_OIDC_REDIRECT=http://vaultwarden.cianfhoghlaim.ie
