# =============================================================================
# BROWSER - Local development environment (no real secrets)
# =============================================================================
# Copy to .env.local and edit. Do NOT commit .env.local.
# =============================================================================

API_PORT=3001
STAGEHAND_PORT=3100
GARAGE_S3_PORT=3900
GARAGE_WEB_PORT=3902
GARAGE_RPC_SECRET=dev-rpc-secret
GARAGE_ADMIN_TOKEN=dev-admin-token
SKYVERN_DB_PASSWORD=dev-skyvern-db
OPENAI_API_KEY=sk-dev
ANTHROPIC_API_KEY=sk-dev
GOOGLE_API_KEY=dev-google
ZAI_API_KEY=dev-zai
BROWSERBASE_API_KEY=dev-browserbase-key
BROWSERBASE_PROJECT_ID=dev-browserbase-project
FIRECRAWL_API_KEY=dev-firecrawl
LANGFUSE_PUBLIC_KEY=pk-dev-langfuse
LANGFUSE_SECRET_KEY=sk-dev-langfuse
ENVIRONMENT=development
LOG_LEVEL=DEBUG
DEFAULT_BACKEND=stagehand
FALLBACK_STRATEGY=cost
LLM_PROVIDER=anthropic
ENABLE_OPENAI=true
ENABLE_ANTHROPIC=true
STAGEHAND_HEADLESS=true
STAGEHAND_MAX_SESSIONS=10
STAGEHAND_SESSION_TTL=300000
STAGEHAND_MODEL=glm-4.6
STAGEHAND_VISION_MODEL=glm-4.6v
STAGEHAND_AGENT_MODEL=google/gemini-3-flash-preview
MAX_CONCURRENT_TASKS=4
