# =============================================================================
# OLM Hetzner - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
#
# PREREQUISITES:
#   1. Create OLM site "cax41-hetzner-olm" in Pangolin UI (Sites -> Create Site -> OLM)
#   2. Copy the ID and Secret from the site creation dialog
#   3. Create 1Password item:
#      op item create --vault dev-baile --title "cax41-hetzner-olm" \
#        id="<olm_id>" secret="<olm_secret>"
#
# USAGE:
#   docker compose -f compose.yaml -f sidecar.yaml up -d
# =============================================================================

# OLM Credentials (from Pangolin site creation)
OLM_ID={{ op://dev-baile/cax41-hetzner-olm/id }}
OLM_SECRET={{ op://dev-baile/cax41-hetzner-olm/secret }}
