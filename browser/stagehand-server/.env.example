# Stagehand Local Server Configuration

# Server
PORT=3100
HEADLESS=true
MAX_SESSIONS=10
SESSION_TTL_MS=300000

# LLM Providers
ZAI_API_KEY=           # GLM-4.6/4.6v
GOOGLE_API_KEY=        # Gemini 3 Flash
OPENAI_API_KEY=        # Fallback

# Browserbase (for cloud fallback)
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=

# Default model for Stagehand operations
DEFAULT_MODEL=glm-4.6
VISION_MODEL=glm-4.6v
AGENT_MODEL=google/gemini-3-flash-preview
