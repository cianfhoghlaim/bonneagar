# =============================================================================
# ROMM - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# Romm Application
# =============================================================================
ROMM_BASE_PATH=/app/romm
DEV_PORT=5000

# =============================================================================
# MariaDB (Game Library Database)
# =============================================================================
DB_HOST=romm-db-dev
DB_NAME=romm
DB_USER=romm
DB_PASSWD=romm
DB_ROOT_PASSWD=rootpassword

# =============================================================================
# PostgreSQL (Authentik Backend)
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=authentik

# =============================================================================
# Redis / Valkey
# =============================================================================
REDIS_PORT=6379

# =============================================================================
# Authentik (SSO / Identity Provider)
# =============================================================================
AUTHENTIK_SECRET_KEY=secret-key-default
AUTHENTIK_BOOTSTRAP_PASSWORD=password

# =============================================================================
# Secrets (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# DB_PASSWD=<strong-password>                       # Set via Locket/Infisical in production
# DB_ROOT_PASSWD=<strong-password>                   # Set via Locket/Infisical in production
# POSTGRES_PASSWORD=<strong-password>                # Set via Locket/Infisical in production
# AUTHENTIK_SECRET_KEY=<random-secret-key>           # Set via Locket/Infisical in production
# AUTHENTIK_BOOTSTRAP_PASSWORD=<admin-password>      # Set via Locket/Infisical in production