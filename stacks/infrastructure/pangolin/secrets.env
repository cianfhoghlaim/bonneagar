# PANGOLIN STACK — Locket Secrets Template (dev-baile)
# Pangolin supports these env vars directly (overrides config.yml):
#   SERVER_SECRET → server.secret
#   POSTGRES_CONNECTION_STRING → postgres.connection_string
# Docs: https://docs.pangolin.net/self-host/advanced/config-file#environment-variables

SERVER_SECRET={{ infisical://dev-baile/pangolin/server_secret }}
POSTGRES_CONNECTION_STRING={{ infisical://dev-baile/pangolin/postgres_connection_string }}

# Bundled Postgres credentials
POSTGRES_PASSWORD={{ infisical://dev-baile/pangolin/postgres_password }}

# PocketID OIDC (TinyAuth forward auth)
POCKETID_CLIENT_ID={{ infisical://dev-baile/pocketid-tinyauth/client_id }}
POCKETID_CLIENT_SECRET={{ infisical://dev-baile/pocketid-tinyauth/client_secret }}
