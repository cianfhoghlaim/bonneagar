# =============================================================================
# CHANGEDETECTION - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# NOTE: changedetection.io compose.yaml has all environment variables
# commented out. This file is a placeholder for when proxy/Playwright
# settings are enabled. Uncomment and fill as needed:
#
# PLAYWRIGHT_DRIVER_URL=ws://browser-sockpuppet-chrome:3000
# HTTP_PROXY=socks5h://10.10.1.10:1080
# HTTPS_PROXY=socks5h://10.10.1.10:1080
# =============================================================================