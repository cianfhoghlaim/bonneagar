# Infisical secret references for the Frontend stack
# Each value is an Infisical URI — never plaintext. Hydrated by Locket sidecar
# at container startup via the dev-baile environment.

# OIDC issuer (croilar-hono-api)
BETTER_AUTH_SECRET=infisical://dev-baile/croilar/BETTER_AUTH_SECRET
BETTER_AUTH_URL=infisical://dev-baile/croilar/BETTER_AUTH_URL

# LiteLLM (LLM gateway for agent chat + BAML extraction)
LITELLM_MASTER_KEY=infisical://dev-baile/litellm/LITELLM_MASTER_KEY
LITELLM_BASE_URL=infisical://dev-baile/litellm/LITELLM_BASE_URL

# MotherDuck (lakehouse Dive embeds in oideachais-web)
MOTHERDUCK_ADMIN_TOKEN=infisical://dev-baile/motherduck/MOTHERDUCK_ADMIN_TOKEN
MOTHERDUCK_DIVE_ID=infisical://dev-baile/motherduck/MOTHERDUCK_DIVE_ID

# Langfuse (observability for all oRPC procedures)
LANGFUSE_PUBLIC_KEY=infisical://dev-baile/langfuse/LANGFUSE_PUBLIC_KEY
LANGFUSE_SECRET_KEY=infisical://dev-baile/langfuse/LANGFUSE_SECRET_KEY
LANGFUSE_HOST=infisical://dev-baile/langfuse/LANGFUSE_HOST

# Convex self-hosted deployment URL
CONVEX_HTTP_URL=infisical://dev-baile/convex/CONVEX_HTTP_URL
VITE_CONVEX_URL=infisical://dev-baile/convex/CONVEX_HTTP_URL

# Service URLs (vault-stored so they can be swapped per environment)
VITE_HONO_API_URL=infisical://dev-baile/services/HONO_API_URL
VITE_AUTH_URL=infisical://dev-baile/services/AUTH_URL
