# =============================================================================
# OLAKE-UI - Locket Secrets Template
# =============================================================================
# Used with: locket exec --env-file secrets.env -- docker compose up -d
# =============================================================================

# Encryption key (AES-256 or AWS KMS ARN)
OLAKE_SECRET_KEY={{ op://taisce-secrets/olake-ui/secret_key }}

# Admin user credentials
OLAKE_ADMIN_USERNAME={{ op://taisce-secrets/olake-ui/admin_username }}
OLAKE_ADMIN_PASSWORD={{ op://taisce-secrets/olake-ui/admin_password }}
OLAKE_ADMIN_EMAIL={{ op://taisce-secrets/olake-ui/admin_email }}

# Temporal PostgreSQL
OLAKE_DB_USER={{ op://taisce-secrets/olake-postgres/username }}
OLAKE_DB_PASSWORD={{ op://taisce-secrets/olake-postgres/password }}
