# =============================================================================
# HF WATCHDOG — Env Var Documentation
# =============================================================================
# Every var in the container's `environment:` block MUST be
# documented here. The stack-doctor validates this on every CI
# run. The values are the DEFAULTS; the Locket sidecar overrides
# with the Infisical values at container start.
# =============================================================================

# Slack webhook URL for posting alerts on HF Hub 404s. Optional;
# if absent, the watchdog logs to stdout instead.
SLACK_WEBHOOK_URL=

# The interval (in seconds) between watchdog runs. Default 86400
# (24h). The watchdog runs at the start of every container + at
# the interval thereafter.
WATCH_INTERVAL=86400

# The HF Hub API base URL. Override for testing.
HF_API_BASE=https://huggingface.co/api

# The cianfhoghlaim image tag to import VISION_MODELS from. The
# watchdog does NOT pull this image; it expects cianfhoghlaim to
# be installed in the runtime environment (via the Dockerfile
# multi-stage build).
CIANFHOGHLAIM_VERSION=dev
