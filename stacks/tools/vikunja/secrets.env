# =============================================================================
# VIKUNJA — Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   vikunja/      postgres_password, service_jwt_secret, mailer_smtp_password, admin_password
#   team-mailbox/ imap_password, smtp_password
# =============================================================================

# Core
VIKUNJA_DATABASE_PASSWORD={{ infisical:///vikunja/postgres_password }}
VIKUNJA_SERVICE_JWT_SECRET={{ infisical:///vikunja/service_jwt_secret }}

# Mailer (reuses the team-mailbox IMAP/SMTP credentials)
VIKUNJA_MAILER_SMTPUSER={{ infisical:///team-mailbox/imap_user }}
VIKUNJA_MAILER_SMTPPASSWORD={{ infisical:///team-mailbox/smtp_password }}

# Admin user for vikunja-seed (one-shot init container)
VIKUNJA_ADMIN_USER=team-lead
VIKUNJA_ADMIN_PASSWORD={{ infisical:///vikunja/admin_password }}
