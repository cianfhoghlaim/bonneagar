# =============================================================================
# CROILAR-WEB - Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile/croilar/:
#   hmac_secret, encryption_key, github_token, spotify_client_id,
#   spotify_client_secret, soundcloud_client_id, soundcloud_client_secret,
#   youtube_api_key, cloudflare_account_id, cloudflare_api_token
# =============================================================================

# Croílár-specific secrets
CROILAR_HMAC_SECRET={{ infisical:///croilar/hmac_secret }}
CROILAR_ENCRYPTION_KEY={{ infisical:///croilar/encryption_key }}
GITHUB_TOKEN={{ infisical:///croilar/github_token }}
SPOTIFY_CLIENT_ID={{ infisical:///croilar/spotify_client_id }}
SPOTIFY_CLIENT_SECRET={{ infisical:///croilar/spotify_client_secret }}
SOUNDCLOUD_CLIENT_ID={{ infisical:///croilar/soundcloud_client_id }}
SOUNDCLOUD_CLIENT_SECRET={{ infisical:///croilar/soundcloud_client_secret }}
YOUTUBE_API_KEY={{ infisical:///croilar/youtube_api_key }}

# Cloudflare (shared across croilar services)
CLOUDFLARE_ACCOUNT_ID={{ infisical:///croilar/cloudflare_account_id }}
CLOUDFLARE_API_TOKEN={{ infisical:///croilar/cloudflare_api_token }}
