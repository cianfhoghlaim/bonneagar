# =============================================================================
# PRESENTON - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - presenton: openai_api_key, google_api_key, anthropic_api_key,
#       custom_llm_api_key, pexels_api_key
# =============================================================================

# =============================================================================
# LLM Provider API Keys
# =============================================================================
OPENAI_API_KEY={{ infisical:///openai_api_key }}
GOOGLE_API_KEY={{ infisical:///google_api_key }}
ANTHROPIC_API_KEY={{ infisical:///anthropic_api_key }}
CUSTOM_LLM_API_KEY={{ infisical:///custom_llm_api_key }}

# =============================================================================
# Media / Search API Keys
# =============================================================================
PEXELS_API_KEY={{ infisical:///pexels_api_key }}

# =============================================================================
# Database Connection
# =============================================================================
DATABASE_URL={{ infisical:///database_url }}

# =============================================================================
# Configuration (non-secret, set as needed)
# =============================================================================
CAN_CHANGE_KEYS=true
LLM=openai
OPENAI_MODEL=gpt-4o
GOOGLE_MODEL=gemini-pro
ANTHROPIC_MODEL=claude-sonnet-4-20250514
EXTENDED_REASONING=false
TOOL_CALLS=false
DISABLE_THINKING=false
WEB_GROUNDING=false
DISABLE_ANONYMOUS_TRACKING=true