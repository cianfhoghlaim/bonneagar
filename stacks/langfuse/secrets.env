# =============================================================================
# LANGFUSE - Locket Secrets Template (dev-baile vault)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
# =============================================================================

# PostgreSQL
DATABASE_URL=infisical://dev-baile/langfuse/database_url
POSTGRES_USER=infisical://dev-baile/langfuse/postgres_user
POSTGRES_PASSWORD=infisical://dev-baile/langfuse/postgres_password

# Application Secrets
SALT=infisical://dev-baile/langfuse/salt
ENCRYPTION_KEY=infisical://dev-baile/langfuse/encryption_key
NEXTAUTH_SECRET=infisical://dev-baile/langfuse/nextauth_secret

# ClickHouse
CLICKHOUSE_USER=infisical://dev-baile/langfuse/clickhouse_user
CLICKHOUSE_PASSWORD=infisical://dev-baile/langfuse/clickhouse_password

# Redis
REDIS_AUTH=infisical://dev-baile/langfuse/redis_auth

# MinIO (S3-compatible storage)
MINIO_ROOT_USER=infisical://dev-baile/langfuse/minio_root_user
MINIO_ROOT_PASSWORD=infisical://dev-baile/langfuse/minio_root_password

# S3 Event Upload
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=infisical://dev-baile/langfuse/event_upload_access_key_id
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=infisical://dev-baile/langfuse/event_upload_secret_access_key

# S3 Media Upload
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=infisical://dev-baile/langfuse/media_upload_access_key_id
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=infisical://dev-baile/langfuse/media_upload_secret_access_key

# S3 Batch Export
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=infisical://dev-baile/langfuse/batch_export_access_key_id
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=infisical://dev-baile/langfuse/batch_export_secret_access_key

# Langfuse Init (first-run bootstrap)
LANGFUSE_INIT_ORG_ID=infisical://dev-baile/langfuse/init_org_id
LANGFUSE_INIT_ORG_NAME=infisical://dev-baile/langfuse/init_org_name
LANGFUSE_INIT_PROJECT_ID=infisical://dev-baile/langfuse/init_project_id
LANGFUSE_INIT_PROJECT_NAME=infisical://dev-baile/langfuse/init_project_name
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=infisical://dev-baile/langfuse/init_project_public_key
LANGFUSE_INIT_PROJECT_SECRET_KEY=infisical://dev-baile/langfuse/init_project_secret_key
LANGFUSE_INIT_USER_EMAIL=infisical://dev-baile/langfuse/init_user_email
LANGFUSE_INIT_USER_NAME=infisical://dev-baile/langfuse/init_user_name
LANGFUSE_INIT_USER_PASSWORD=infisical://dev-baile/langfuse/init_user_password
