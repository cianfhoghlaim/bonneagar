# =============================================================================
# PANGOLIN - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses 1Password Connect references (op://vault/item/field).
#
# USAGE WITH LOCKET EXEC:
#   locket exec --provider op-connect \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /etc/connect/token \
#     --env-file secrets.env \
#     -- docker compose up -d
#
# USAGE WITH SIDECAR:
#   docker compose -f compose.yaml -f sidecar.yaml up -d
#
# REQUIRED 1PASSWORD ITEMS:
#   - dev-baile/pangolin: server_secret, postgres_password
#   - dev-baile/cloudflare: api_token
#   - dev-baile/pocketid-tinyauth: client_id, client_secret
#   - dev-baile/crowdsec: bouncer_key
# =============================================================================

# Pangolin Core Secrets
SERVER_SECRET={{ op://dev-baile/pangolin/server_secret }}

# PostgreSQL Credentials
POSTGRES_PASSWORD={{ op://dev-baile/pangolin/postgres_password }}

# Cloudflare DNS API Token (for wildcard certificate DNS challenge)
CF_DNS_API_TOKEN={{ op://dev-baile/cloudflare/api_token }}

# PocketID OAuth Client (for TinyAuth SSO integration)
POCKETID_CLIENT_ID={{ op://dev-baile/pocketid-tinyauth/client_id }}
POCKETID_CLIENT_SECRET={{ op://dev-baile/pocketid-tinyauth/client_secret }}

# CrowdSec Bouncer Key (generated after first deployment)
# Run: docker exec crowdsec cscli bouncers add traefik-bouncer
# Then store result in 1Password
CROWDSEC_BOUNCER_KEY={{ op://dev-baile/crowdsec/bouncer_key }}
