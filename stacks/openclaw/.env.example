# =============================================================================
# OPENCLAW — Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local
# Then: docker compose -f compose.yaml -f sidecar.yaml up -d
#
# All values that resolve to "infisical://dev-baile/..." URIs are populated
# at runtime by the Locket sidecar. Only put non-secret defaults here.
# =============================================================================

# =============================================================================
# Gateway
# =============================================================================
OPENCLAW_PORT=18789
OPENCLAW_BRIDGE_PORT=18790
OPENCLAW_LOG_LEVEL=info

# =============================================================================
# Auth model
# =============================================================================
# 3-layer auth:
#   1. Pangolin TinyAuth (Pocket ID OIDC) — required by the Traefik route
#   2. openclaw dmPolicy=pairing — sender must pair before any agent routes
#   3. allow_from list (empty = everything must pair)
OPENCLAW_DM_POLICY=pairing
# OPENCLAW_ALLOW_FROM=alice@example.com,bob@example.com

# =============================================================================
# Channels (set in .env.local for dev, or via Locket/Infisical in prod)
# =============================================================================
# OPENCLAW_ENABLE_TELEGRAM=true
# OPENCLAW_ENABLE_SLACK=true
# OPENCLAW_ENABLE_DISCORD=true
# OPENCLAW_ENABLE_WHATSAPP=true
# OPENCLAW_ENABLE_TEAMS=true
# OPENCLAW_ENABLE_SIGNAL=false   # requires signal-cli
# OPENCLAW_ENABLE_IMESSAGE=false # requires BlueBubbles on macOS
# OPENCLAW_ENABLE_MATRIX=false   # requires Matrix homeserver

# =============================================================================
# Public hostname (used by pangolin.yaml blueprint)
# =============================================================================
PANGOLIN_DOMAIN=openclaw.cianfhoghlaim.ie