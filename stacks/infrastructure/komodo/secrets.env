# Komodo dev secrets file — minimal env injection for local development.
# In production this is replaced by the Locket sidecar pulling from
# Infisical `dev-baile` (path /komodo). The keys here are placeholders
# safe for dev only; do not deploy to arm1-oci with this file.
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=devpassword
