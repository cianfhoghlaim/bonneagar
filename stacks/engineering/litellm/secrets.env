# =============================================================================
# LITELLM GATEWAY — Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical URI references (infisical://dev-baile/<item>/<key>).
#
# LOCKET USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml -f sidecar.yaml up -d
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   - litellm: master_key, salt_key, database_url,
#               postgres_user, postgres_password, postgres_db
# =============================================================================

# Gateway
LITELLM_MASTER_KEY={{ infisical://dev-baile/litellm/master_key }}
LITELLM_SALT_KEY={{ infisical://dev-baile/litellm/salt_key }}

# LiteLLM Postgres (separate from lakehouse; holds model registry)
LITELLM_DATABASE_URL={{ infisical://dev-baile/litellm/database_url }}
LITELLM_POSTGRES_USER={{ infisical://dev-baile/litellm/postgres_user }}
LITELLM_POSTGRES_PASSWORD={{ infisical://dev-baile/litellm/postgres_password }}
LITELLM_POSTGRES_DB={{ infisical://dev-baile/litellm/postgres_db }}
