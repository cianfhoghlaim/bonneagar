# =============================================================================
# LANGFUSE - Locket Secrets Template (dev-baile vault)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
#
# Updated for the `centralise-data-plane` rewrite (2026-07-30):
# - DATABASE_URL, POSTGRES_USER, POSTGRES_PASSWORD now resolved via the
#   lakehouse stack's secrets.env (shared).
# - The standalone POSTGRES_PASSWORD, MINIO_ROOT_USER/PASSWORD,
#   CLICKHOUSE_USER/PASSWORD, REDIS_AUTH, and per-bucket
#   S3 access/secret keys were dropped.
# - Per-bucket S3 access keys are now the SHARED garage credentials
#   (GARAGE_ACCESS_KEY_ID / GARAGE_SECRET_ACCESS_KEY).
# - Langfuse-specific secrets that stay here: SALT, ENCRYPTION_KEY,
#   NEXTAUTH_SECRET, plus the optional LANGFUSE_INIT_* first-run
#   bootstrap values.
# =============================================================================

# ---------------------------------------------------------------------------
# Shared data-plane credentials (resolved from the lakehouse vault)
# ---------------------------------------------------------------------------
# These mirror lakehouse/secrets.env entries — the langfuse stack reads
# them from the Locket volume shared between stacks.
POSTGRES_USER=infisical://dev-baile/lakehouse/postgres_user
POSTGRES_PASSWORD=infisical://dev-baile/lakehouse/postgres_password
GARAGE_ACCESS_KEY_ID=infisical://dev-baile/lakehouse-garage/access_key_id
GARAGE_SECRET_ACCESS_KEY=infisical://dev-baile/lakehouse-garage/secret_access_key
CLICKHOUSE_USER=infisical://dev-baile/lakehouse-clickhouse/user
CLICKHOUSE_PASSWORD=infisical://dev-baile/lakehouse-clickhouse/password
REDIS_PASSWORD=infisical://dev-baile/lakehouse-redis/password

# ---------------------------------------------------------------------------
# Application secrets (langfuse-specific)
# ---------------------------------------------------------------------------
SALT=infisical://dev-baile/langfuse/salt
ENCRYPTION_KEY=infisical://dev-baile/langfuse/encryption_key
NEXTAUTH_SECRET=infisical://dev-baile/langfuse/nextauth_secret

# ---------------------------------------------------------------------------
# First-run bootstrap (optional; only on initial deploy)
# ---------------------------------------------------------------------------
LANGFUSE_INIT_ORG_ID=infisical://dev-baile/langfuse/init_org_id
LANGFUSE_INIT_ORG_NAME=infisical://dev-baile/langfuse/init_org_name
LANGFUSE_INIT_PROJECT_ID=infisical://dev-baile/langfuse/init_project_id
LANGFUSE_INIT_PROJECT_NAME=infisical://dev-baile/langfuse/init_project_name
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=infisical://dev-baile/langfuse/init_project_public_key
LANGFUSE_INIT_PROJECT_SECRET_KEY=infisical://dev-baile/langfuse/init_project_secret_key
LANGFUSE_INIT_USER_EMAIL=infisical://dev-baile/langfuse/init_user_email
LANGFUSE_INIT_USER_NAME=infisical://dev-baile/langfuse/init_user_name
LANGFUSE_INIT_USER_PASSWORD=infisical://dev-baile/langfuse/init_user_password

# ---------------------------------------------------------------------------
# Compatibility entries — kept for backward compat with the legacy
# per-stack secrets. The compose.yaml ignores these now that we're
# reading from the centralised lakehouse vault. Will be removed in the
# next cleanup-and-boot-stacks change.
# ---------------------------------------------------------------------------
# DATABASE_URL=infisical://dev-baile/langfuse/database_url  # now inherited from lakehouse
# POSTGRES_USER=infisical://dev-baile/langfuse/postgres_user  # now inherited
# MINIO_ROOT_USER=infisical://dev-baile/langfuse/minio_root_user  # now GARAGE_ACCESS_KEY_ID
# MINIO_ROOT_PASSWORD=infisical://dev-baile/langfuse/minio_root_password  # now GARAGE_SECRET_ACCESS_KEY
# CLICKHOUSE_USER=infisical://dev-baile/langfuse/clickhouse_user  # now inherited
# CLICKHOUSE_PASSWORD=infisical://dev-baile/langfuse/clickhouse_password  # now inherited
# REDIS_AUTH=infisical://dev-baile/langfuse/redis_auth  # now REDIS_PASSWORD
# LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID=infisical://dev-baile/langfuse/event_upload_access_key_id  # now GARAGE_ACCESS_KEY_ID
# LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY=infisical://dev-baile/langfuse/event_upload_secret_access_key  # now GARAGE_SECRET_ACCESS_KEY
# LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID=infisical://dev-baile/langfuse/media_upload_access_key_id  # now GARAGE_ACCESS_KEY_ID
# LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY=infisical://dev-baile/langfuse/media_upload_secret_access_key  # now GARAGE_SECRET_ACCESS_KEY
# LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID=infisical://dev-baile/langfuse/batch_export_access_key_id  # now GARAGE_ACCESS_KEY_ID
# LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY=infisical://dev-baile/langfuse/batch_export_secret_access_key  # now GARAGE_SECRET_ACCESS_KEY
