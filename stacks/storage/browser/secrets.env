# =============================================================================
# BROWSER STACK - Secrets Template (Locket)
# =============================================================================
# These infisical:// references are resolved by Locket at runtime from Infisical
# Vault: dev-baile
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY={{ infisical:///api-key }}
OPENAI_API_KEY={{ infisical:///api-key }}
GOOGLE_API_KEY={{ infisical:///api-key }}
ZAI_API_KEY={{ infisical:///api-key }}

# -----------------------------------------------------------------------------
# Paid Browser Backend APIs
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY={{ infisical:///api-key }}
BROWSERBASE_PROJECT_ID={{ infisical:///project-id }}
FIRECRAWL_API_KEY={{ infisical:///api-key }}

# -----------------------------------------------------------------------------
# Skyvern Database
# -----------------------------------------------------------------------------
SKYVERN_DB_PASSWORD={{ infisical:///password }}

# -----------------------------------------------------------------------------
# Garage S3 Storage
# -----------------------------------------------------------------------------
GARAGE_RPC_SECRET={{ infisical:///rpc-secret }}
GARAGE_ADMIN_TOKEN={{ infisical:///admin-token }}

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY={{ infisical:///public-key }}
LANGFUSE_SECRET_KEY={{ infisical:///secret-key }}
