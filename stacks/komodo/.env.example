# =============================================================================
# KOMODO - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# Komodo Core
# =============================================================================
KOMODO_IMAGE_TAG=2
KOMODO_PORT=9120
KOMODO_HOST=https://komodo.cianfhoghlaim.ie
KOMODO_LOCAL_AUTH=true
KOMODO_INIT_ADMIN_USERNAME=ciansedai

# Database
KOMODO_DATABASE_ADDRESS=mongo:27017
KOMODO_DATABASE_USERNAME=komodo
KOMODO_DATABASE_PASSWORD=devpassword

# Logging & Rate Limiting
KOMODO_AUTH_RATE_LIMIT_DISABLED=true
KOMODO_AUTH_RATE_LIMIT_MAX_ATTEMPTS=250
KOMODO_REQUEST_RATE_LIMIT=500

# Backups
KOMODO_BACKUP_ENABLED=true
KOMODO_BACKUP_SCHEDULE=0 2 * * *

# OIDC (disabled by default)
KOMODO_OIDC_ENABLED=false

# =============================================================================
# MongoDB
# =============================================================================
MONGO_INITDB_ROOT_USERNAME=komodo
MONGO_INITDB_ROOT_PASSWORD=devpassword

# =============================================================================
# Secrets (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# KOMODO_DATABASE_PASSWORD=<strong-password>       # Set via Locket/Infisical in production
# MONGO_INITDB_ROOT_PASSWORD=<strong-password>      # Set via Locket/Infisical in production
# KOMODO_JWT_SECRET=<random-secret>                  # Set via Locket/Infisical in production
# KOMODO_PASSKEY=<passkey>                           # Set via Locket/Infisical in production
# KOMODO_WEBHOOK_SECRET=<webhook-secret>             # Set via Locket/Infisical in production
# KOMODO_INIT_ADMIN_PASSWORD=<admin-password>        # Set via Locket/Infisical in production
# KOMODO_OIDC_PROVIDER=<oidc-provider-url>          # Set via Locket/Infisical in production
# KOMODO_OIDC_CLIENT_ID=<oidc-client-id>            # Set via Locket/Infisical in production
# KOMODO_OIDC_CLIENT_SECRET=<oidc-client-secret>    # Set via Locket/Infisical in production