# =============================================================================
# MLFLOW - Locket Secrets Template (dev-baile vault)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
#
# Updated for the `centralise-data-plane` rewrite (2026-07-30):
# - POSTGRES_PASSWORD + GARAGE_ACCESS_KEY_ID + GARAGE_SECRET_ACCESS_KEY
#   now resolved from the lakehouse-* vaults (shared).
# - The legacy POSTGRES_PASSWORD / MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
#   entries are dropped; they're inherited from the lakehouse stack.
# =============================================================================

# ---------------------------------------------------------------------------
# Shared data-plane credentials (resolved from the lakehouse vault)
# ---------------------------------------------------------------------------
POSTGRES_USER=infisical://dev-baile/lakehouse/postgres_user
POSTGRES_PASSWORD=infisical://dev-baile/lakehouse/postgres_password
GARAGE_ACCESS_KEY_ID=infisical://dev-baile/lakehouse-garage/access_key_id
GARAGE_SECRET_ACCESS_KEY=infisical://dev-baile/lakehouse-garage/secret_access_key
AWS_DEFAULT_REGION=infisical://dev-baile/mlflow/aws_default_region
MLFLOW_DEFAULT_ARTIFACT_ROOT=infisical://dev-baile/mlflow/default_artifact_root

# ---------------------------------------------------------------------------
# MLflow-specific secrets (optional; for SSO etc.)
# ---------------------------------------------------------------------------
# Add per-stack mlflow-specific keys here as needed. None currently.
