# =============================================================================
# Oideachais stack — Infisical URI references (NO plaintext)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Gateway
# -----------------------------------------------------------------------------
LITELLM_MASTER_KEY=infisical://dev-baile/litellm/master_key
LLM_API_KEY=infisical://dev-baile/litellm/api_key

# -----------------------------------------------------------------------------
# OpenAI / Anthropic (direct, for BAML client)
# -----------------------------------------------------------------------------
OPENAI_API_KEY=infisical://dev-baile/openai/api_key
ANTHROPIC_API_KEY=infisical://dev-baile/anthropic/api_key

# -----------------------------------------------------------------------------
# Storage: Garage S3 (lakehouse) + Cloudflare R2
# -----------------------------------------------------------------------------
GARAGE_ACCESS_KEY_ID=infisical://dev-baile/garage/access_key_id
GARAGE_SECRET_ACCESS_KEY=infisical://dev-baile/garage/secret_access_key
R2_ACCESS_KEY=infisical://dev-baile/cloudflare/r2_access_key
R2_SECRET_KEY=infisical://dev-baile/cloudflare/r2_secret_key
MOTHERDUCK_TOKEN=infisical://dev-baile/motherduck/token
LANCEDB_API_KEY=infisical://dev-baile/lancedb/api_key

# -----------------------------------------------------------------------------
# Database (DuckLake Postgres)
# -----------------------------------------------------------------------------
DUCKLAKE_POSTGRES_PASSWORD=infisical://dev-baile/lakehouse/postgres_password

# -----------------------------------------------------------------------------
# Scraping
# -----------------------------------------------------------------------------
FIRECRAWL_API_KEY=infisical://dev-baile/firecrawl/api_key
BROWSERBASE_API_KEY=infisical://dev-baile/browserbase/api_key
BROWSERBASE_PROJECT_ID=infisical://dev-baile/browserbase/project_id

# -----------------------------------------------------------------------------
# OpenCode Go API (analysis layer)
# -----------------------------------------------------------------------------
OPENCODE_GO_API_KEY=infisical://dev-baile/opencode-go/api_key

# -----------------------------------------------------------------------------
# Better Auth
# -----------------------------------------------------------------------------
BETTER_AUTH_SECRET=infisical://dev-baile/betterauth/secret
BETTER_AUTH_URL=infisical://dev-baile/betterauth/url

# -----------------------------------------------------------------------------
# HuggingFace (HTR / OCR model pulls)
# -----------------------------------------------------------------------------
HF_TOKEN=infisical://dev-baile/huggingface/token
HUGGINGFACE_HUB_TOKEN=infisical://dev-baile/huggingface/token

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=infisical://dev-baile/langfuse/public_key
LANGFUSE_SECRET_KEY=infisical://dev-baile/langfuse/secret_key
MLFLOW_TRACKING_URI=infisical://dev-baile/mlflow/uri
LOGFIRE_TOKEN=infisical://dev-baile/logfire/token
