# =============================================================================
# DAGSTER UNIFIED - Local development environment (no real secrets)
# =============================================================================
# Copy to .env.local and edit. Do NOT commit .env.local.
# Locket + sidecar.yaml override these in production.
# =============================================================================

DAGSTER_PORT=3335
USE_DUCKLAKE=true
DUCKLAKE_POSTGRES_HOST=lakehouse-postgres
DUCKLAKE_POSTGRES_PORT=5432
DUCKLAKE_POSTGRES_USER=lakekeeper
DUCKLAKE_POSTGRES_PASSWORD=dev-ducklake-password
DLT_ENVIRONMENT=development
AWS_ACCESS_KEY_ID=dev-garage-key
AWS_SECRET_ACCESS_KEY=dev-garage-secret
AWS_ENDPOINT_URL=http://lakehouse-garage:3900
AWS_REGION=garage
ANTHROPIC_API_KEY=sk-dev-anthropic
OPENAI_API_KEY=sk-dev-openai
LANGFUSE_PUBLIC_KEY=pk-dev-langfuse
LANGFUSE_SECRET_KEY=sk-dev-langfuse
LANGFUSE_HOST=http://localhost:3000
