# =============================================================================
# FORGEJO - Secrets Template (Locket)
# =============================================================================
# These op:// references are resolved by Locket at runtime
# Vault: dev-baile

FORGEJO_DB_PASSWORD={{ op://dev-baile/forgejo-db/password }}
FORGEJO_SECRET_KEY={{ op://dev-baile/forgejo/secret-key }}
FORGEJO_INTERNAL_TOKEN={{ op://dev-baile/forgejo/internal-token }}

# PocketID OAuth2 (for SSO login)
POCKETID_CLIENT_ID={{ op://dev-baile/forgejo-oidc/client_id }}
POCKETID_CLIENT_SECRET={{ op://dev-baile/forgejo-oidc/client_secret }}
