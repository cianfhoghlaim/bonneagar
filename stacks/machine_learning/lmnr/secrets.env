# =============================================================================
# LMNR - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///<SECRET_KEY>).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - lmnr-db: user, password, db
#   - lmnr-clickhouse: user, password, ro_user, ro_password
#   - lmnr-app: shared_secret_token, aead_secret_key, openai_api_key
# =============================================================================

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER={{ infisical:///postgres_user }}
POSTGRES_PASSWORD={{ infisical:///postgres_password }}
POSTGRES_DB={{ infisical:///postgres_db }}

# =============================================================================
# ClickHouse
# =============================================================================
CLICKHOUSE_USER={{ infisical:///clickhouse_user }}
CLICKHOUSE_PASSWORD={{ infisical:///clickhouse_password }}
CLICKHOUSE_RO_USER={{ infisical:///clickhouse_ro_user }}
CLICKHOUSE_RO_PASSWORD={{ infisical:///clickhouse_ro_password }}

# =============================================================================
# Application Secrets
# =============================================================================
SHARED_SECRET_TOKEN={{ infisical:///shared_secret_token }}
AEAD_SECRET_KEY={{ infisical:///aead_secret_key }}

# =============================================================================
# LLM Provider
# =============================================================================
OPENAI_API_KEY={{ infisical:///openai_api_key }}