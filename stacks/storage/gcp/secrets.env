# Google Cloud Platform Configuration
# For AI Partner Catalyst hackathon - Vertex AI / Gemini integration
# Docs: https://cloud.google.com/vertex-ai

# Project configuration
GOOGLE_CLOUD_PROJECT={{ infisical:///project_id }}
VERTEX_AI_LOCATION={{ infisical:///location }}

# Gemini API key (for direct API access)
GEMINI_API_KEY={{ infisical:///gemini_api_key }}

# Service account credentials (for SDK usage)
# Mount as file via Locket sidecar or inject directly
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/locket/gcp-credentials.json
