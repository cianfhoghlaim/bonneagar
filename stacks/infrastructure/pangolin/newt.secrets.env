# =============================================================================
# NEWT - Locket Secrets Template (dev-baile)
# =============================================================================
# Newt site credentials for Pangolin tunnel agents.
# Vault: dev-baile

# arm1-oci (OCI ARM instance)
NEWT_ARM1_ID={{ infisical://dev-baile/pangolin/newt-arm1-oci/id }}
NEWT_ARM1_SECRET={{ infisical://dev-baile/pangolin/newt-arm1-oci/secret }}

# bunchloch (MacBook M4 workload host)
NEWT_BUNCHLOCH_ID={{ infisical://dev-baile/pangolin/newt-bunchloch/id }}
NEWT_BUNCHLOCH_SECRET={{ infisical://dev-baile/pangolin/newt-bunchloch/secret }}
