# =============================================================================
# PlanetScale - Managed PostgreSQL ($5/mo Scaler Plan)
# =============================================================================
# Credentials stored in Infisical: taisce-secrets/planetscale
#
# Region: eu-west-3 (Paris)
# Host: eu-west-3.pg.psdb.cloud
# =============================================================================

PLANETSCALE_HOST=eu-west-3.pg.psdb.cloud
PLANETSCALE_PORT=5432
PLANETSCALE_SSLMODE=require

# Langfuse Database (primary)
PLANETSCALE_LANGFUSE_DATABASE=langfuse
PLANETSCALE_LANGFUSE_USERNAME={{ infisical:///username }}
PLANETSCALE_LANGFUSE_PASSWORD={{ infisical:///password }}

# MLflow Database (future migration)
PLANETSCALE_MLFLOW_DATABASE=mlflow
PLANETSCALE_MLFLOW_USERNAME={{ infisical:///username }}
PLANETSCALE_MLFLOW_PASSWORD={{ infisical:///password }}

# Cognee Database (future migration)
PLANETSCALE_COGNEE_DATABASE=cognee
PLANETSCALE_COGNEE_USERNAME={{ infisical:///username }}
PLANETSCALE_COGNEE_PASSWORD={{ infisical:///password }}
