# Cognee stack — Cianfhoghlaim Oideachais
# LLM via LiteLLM proxy (infrastructure/stacks/engineering/litellm, port 4000)
# Production: LLM_MODEL=deepseek/deepseek-chat (works around the Gemini 403 block)
# For Irish-heavy workloads: override LLM_MODEL=local/irish/uccix
# All keys are Infisical URI refs — Locket resolves at container start.

# LiteLLM master key (read by cognee as LLM_API_KEY / EMBEDDING_API_KEY).
# NOTE: cognee's openai client sends LLM_API_KEY in the Authorization header
# to the proxy. The proxy then forwards it as the upstream API key (which
# DeepSeek rejects). In compose.yaml we set LLM_API_KEY=no-key-needed so the
# proxy falls back to its own DEEPSEEK_API_KEY env var (Locket-managed).
LITELLM_API_KEY=infisical://dev-baile/litellm/master_key

# Cognee postgres password
COGNEE_POSTGRES_PASSWORD=infisical://dev-baile/cognee/postgres_password

# LanceDB API key (cognee writes embedding vectors to Lance Namespace at lakehouse-lance-namespace:8182)
LANCEDB_API_KEY=infisical://dev-baile/lancedb/api_key

# Optional: override the LiteLLM model alias (default: deepseek/deepseek-chat)
# COGNEE_LLM_MODEL=extract              # Gemini 2.5 Pro → GLM 4.6 → Gemini Flash (blocked)
# COGNEE_LLM_MODEL=local/irish/uccix    # Local GGUF Irish
# COGNEE_LLM_MODEL=openai/glm-4.6       # Cloud GLM 4.6

# Optional: override the LiteLLM embedding model (default: openai/text-embedding-3-small)
# The full litellm model path is required (cognee validates against tiktoken at startup).
# COGNEE_EMBEDDING_MODEL=openai/text-embedding-3-small  # default
# COGNEE_EMBEDDING_MODEL=huggingface/BAAI/bge-m3       # BGE-M3 1024d
