# =============================================================================
# OPENCHAMBER — Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile/openchamber/:
#   ui_password       — 2nd-factor UI password (random 32 chars, openssl rand -hex 16)
#   openai_api_key    — OpenAI provider key for OpenCode runtime
#   anthropic_api_key — Anthropic provider key
#   minimax_api_key   — minimax-compatible provider key (default in v1)
# =============================================================================

# UI 2nd-factor auth (Pocket ID OIDC at Pangolin is the primary auth)
OPENCHAMBER_UI_PASSWORD={{ infisical:///openchamber/ui_password }}

# LLM provider keys (any missing key gracefully disables the corresponding provider)
OPENAI_API_KEY={{ infisical:///openchamber/openai_api_key }}
ANTHROPIC_API_KEY={{ infisical:///openchamber/anthropic_api_key }}
MINIMAX_API_KEY={{ infisical:///openchamber/minimax_api_key }}