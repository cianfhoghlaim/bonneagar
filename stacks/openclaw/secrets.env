# =============================================================================
# OPENCLAW — Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# NAMESPACING CONVENTION:
#   - .infisical.env (global, committed): uses OPENCLAW_ prefix to avoid
#     collisions with other stacks (e.g. MINIMAX_API_KEY is defined globally
#     for several other stacks too).
#     e.g. OPENCLAW_MINIMAX_API_KEY=infisical://dev-baile/openclaw/minimax_api_key
#   - secrets.env (stack-local, injected into ONE container): uses the bare
#     env var name that the openclaw process reads directly. Locket resolves
#     `{{ infisical:///openclaw/<key> }}` placeholders by writing each value
#     into the openclaw container's environment.
#     e.g. MINIMAX_API_KEY={{ infisical:///openclaw/minimax_api_key }}
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile/openclaw/ (11 total):
#   gateway_token              — admin API token (random 32-char hex)
#   opencode_go_api_key        — OpenCode Go single-key (primary LLM)
#   minimax_api_key            — fallback LLM (minimax-coding-plan/minimax-m3)
#   telegram_bot_token         — Telegram BotFather bot token
#   slack_bot_token            — Slack bot OAuth token (xoxb-...)
#   slack_app_token            — Slack app-level token (xapp-...)
#   discord_bot_token          — Discord bot token
#   whatsapp_access_token      — WhatsApp Business API access token
#   whatsapp_phone_number_id   — WhatsApp Business phone-number ID
#   teams_bot_token            — Microsoft Teams bot token
#   otel_exporter_otlp_endpoint — Langfuse OTLP/HTTP endpoint
# =============================================================================

# Gateway admin API token (used to call /api/pairing/* and /api/channels/*)
OPENCLAW_GATEWAY_TOKEN={{ infisical:///openclaw/gateway_token }}

# LLM primary — OpenCode Go gateway single-key
OPENCODE_GO_API_KEY={{ infisical:///openclaw/opencode_go_api_key }}

# LLM fallback — minimax subscription (minimax-coding-plan/minimax-m3)
MINIMAX_API_KEY={{ infisical:///openclaw/minimax_api_key }}

# Channel credentials (resolved at startup; missing values just disable the channel)
TELEGRAM_BOT_TOKEN={{ infisical:///openclaw/telegram_bot_token }}
SLACK_BOT_TOKEN={{ infisical:///openclaw/slack_bot_token }}
SLACK_APP_TOKEN={{ infisical:///openclaw/slack_app_token }}
DISCORD_BOT_TOKEN={{ infisical:///openclaw/discord_bot_token }}
WHATSAPP_ACCESS_TOKEN={{ infisical:///openclaw/whatsapp_access_token }}
WHATSAPP_PHONE_NUMBER_ID={{ infisical:///openclaw/whatsapp_phone_number_id }}
TEAMS_BOT_TOKEN={{ infisical:///openclaw/teams_bot_token }}

# Observability — Langfuse OTLP/HTTP
OTEL_EXPORTER_OTLP_ENDPOINT={{ infisical:///openclaw/otel_exporter_otlp_endpoint }}