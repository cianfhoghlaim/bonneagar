# Olake source connector configuration (extends-lakehouse-with-nimtable-olake-lancedb)
# ---------------------------------------------------------------------------
# Set OLAKE_SOURCE_TYPE to one of: postgres | mysql | mongodb
# The corresponding *_HOST / *_PORT / *_DB / *_USER / *_PASSWORD env vars are
# picked up by the source-connector process at startup. For postgres CDC you
# also need OLAKE_REPLICATION_SLOT + OLAKE_PUBLICATION set on the source DB.
# ---------------------------------------------------------------------------

OLAKE_SOURCE_TYPE=postgres

# Postgres source (change as needed)
OLAKE_SOURCE_HOST=postgres
OLAKE_SOURCE_PORT=5432
OLAKE_SOURCE_DB=staging_pg
OLAKE_SOURCE_USER=lakekeeper
OLAKE_SOURCE_PASSWORD=devpassword
OLAKE_SOURCE_SSLMODE=prefer

# Postgres CDC prerequisites (run on the SOURCE DB once, NOT here)
#   CREATE PUBLICATION olake_pub FOR TABLE public.users, public.orders, public.events;
#   SELECT pg_create_logical_replication_slot('olake_slot', 'pgoutput');
OLAKE_REPLICATION_SLOT=olake_slot
OLAKE_PUBLICATION=olake_pub

# MongoDB source (uncomment + set OLAKE_SOURCE_TYPE=mongodb to use)
# OLAKE_SOURCE_HOST=mongo
# OLAKE_SOURCE_PORT=27017
# OLAKE_SOURCE_DB=staging
# OLAKE_SOURCE_USER=root
# OLAKE_SOURCE_PASSWORD=devpassword

# MySQL source (uncomment + set OLAKE_SOURCE_TYPE=mysql to use)
# OLAKE_SOURCE_HOST=mysql
# OLAKE_SOURCE_PORT=3306
# OLAKE_SOURCE_DB=staging
# OLAKE_SOURCE_USER=root
# OLAKE_SOURCE_PASSWORD=devpassword
