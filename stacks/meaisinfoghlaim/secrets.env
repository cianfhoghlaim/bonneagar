# =============================================================================
# MEAISÍNFHOGHLAIM - Locket Secrets Template
# =============================================================================
# This stack hosts llama-swap (the dynamic GGUF model swapper). It does not
# require cloud LLM API keys — the upstream LiteLLM gateway handles those.
# However, llama-swap needs to know the HF_HOME so it can pre-fetch any
# missing GGUF files at runtime.
# =============================================================================

# HuggingFace token (used by llama-server if it needs to fetch on the fly)
HF_TOKEN={{ infisical://dev-baile/huggingface/token }}
HUGGINGFACE_HUB_TOKEN={{ infisical://dev-baile/huggingface/token }}
HUGGINGFACE_TOKEN={{ infisical://dev-baile/huggingface/token }}
