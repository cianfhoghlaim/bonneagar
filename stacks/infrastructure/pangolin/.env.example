# =============================================================================
# PANGOLIN STACK — Environment variables (DEPLOY)
# =============================================================================
# Place this file at /opt/pangolin/.env on arm1-oci
# DO NOT COMMIT THIS FILE (gitignored via .env in repo root)
#
# Required secrets come from the locket sidecar which resolves them from
# Infisical at runtime. The two values that MUST be set in this file
# (because locket can't read them) are:
#   - INFISICAL_CLIENT_ID: the universal-auth machine identity client_id
#   - INFISICAL_PROJECT_ID: the workspace ID where pangolin secrets live
#   - INFISICAL_SECRET_FILE: path to the file containing the locket's
#     machine-identity secret (see bun run scripts/init-vault.ts)
# =============================================================================

# Infisical auth for Locket sidecar
INFISICAL_CLIENT_ID=c56cbe28-88a4-4793-95a1-835d5164d8ad
INFISICAL_PROJECT_ID=f3cff583-b74b-4804-b9d3-db8b68885236
INFISICAL_SECRET_FILE=/opt/pangolin/config/infisical_secret

# Locket mode: "watch" (continuous sync) or "run" (one-shot)
LOCKET_MODE=watch

# Cloudflare DNS-01 token (used by traefik's letsencrypt-wildcard resolver
# for the *.cianfhoghlaim.ie cert renewal — traefik shares gerbil's net ns)
# Get from Cloudflare dashboard → Profile → API Tokens
# Required permission: Zone: DNS: Edit on cianfhoghlaim.ie
CLOUDFLARE_DNS_API_TOKEN=__FILL_IN__
