# =============================================================================
# GLUETUN - Locket Secrets Template
# =============================================================================
# WireGuard credentials (private key + endpoint + preshared key).
# =============================================================================

WIREGUARD_PRIVATE_KEY={{ infisical://dev-baile/gluetun/wireguard_private_key }}
WIREGUARD_PRESHARED_KEY={{ infisical://dev-baile/gluetun/wireguard_preshared_key }}
WIREGUARD_ADDRESSES={{ infisical://dev-baile/gluetun/wireguard_addresses }}
WIREGUARD_PUBKEY={{ infisical://dev-baile/gluetun/wireguard_pubkey }}
WIREGUARD_ENDPOINT={{ infisical://dev-baile/gluetun/wireguard_endpoint }}
