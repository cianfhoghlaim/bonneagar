# =============================================================================
# LITELLM - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# PostgreSQL Database (non-secret defaults for local dev)
# =============================================================================
POSTGRES_DB=litellm
POSTGRES_USER=llmproxy
POSTGRES_PASSWORD=dbpassword9090

DATABASE_URL=postgresql://llmproxy:dbpassword9090@db:5432/litellm

# =============================================================================
# LiteLLM Proxy
# =============================================================================
STORE_MODEL_IN_DB=True

# =============================================================================
# Secrets (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# LITELLM_MASTER_KEY=sk-1234              # Admin API key for proxy
# OPENAI_API_KEY=sk-...                     # Set via Locket/Infisical in production
# ANTHROPIC_API_KEY=sk-ant-...              # Set via Locket/Infisical in production
# AWS_ACCESS_KEY_ID=...                     # Set via Locket/Infisical in production
# AWS_SECRET_ACCESS_KEY=...                 # Set via Locket/Infisical in production