# =============================================================================
# LANGFUSE - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses 1Password Connect references (op://vault/item/field).
#
# USAGE:
#   locket exec --provider op-connect \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
# =============================================================================

# PostgreSQL
POSTGRES_USER={{ op://taisce-secrets/langfuse-postgres/username }}
POSTGRES_PASSWORD={{ op://taisce-secrets/langfuse-postgres/password }}
POSTGRES_DB={{ op://taisce-secrets/langfuse-postgres/database }}

# ClickHouse
CLICKHOUSE_USER={{ op://taisce-secrets/langfuse-clickhouse/username }}
CLICKHOUSE_PASSWORD={{ op://taisce-secrets/langfuse-clickhouse/password }}

# Redis
REDIS_AUTH={{ op://taisce-secrets/langfuse-redis/password }}

# MinIO
MINIO_ROOT_USER={{ op://taisce-secrets/langfuse-minio/username }}
MINIO_ROOT_PASSWORD={{ op://taisce-secrets/langfuse-minio/password }}

# Authentication
NEXTAUTH_SECRET={{ op://taisce-secrets/langfuse-auth/nextauth_secret }}
SALT={{ op://taisce-secrets/langfuse-auth/salt }}
ENCRYPTION_KEY={{ op://taisce-secrets/langfuse-auth/encryption_key }}
