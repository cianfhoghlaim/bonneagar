# =============================================================================
# LANGFUSE - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///<SECRET_KEY>).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - langfuse-db: user, password, db, database_url
#   - langfuse-app: salt, encryption_key, nextauth_secret
#   - langfuse-clickhouse: user, password
#   - langfuse-redis: auth
#   - langfuse-minio: root_user, root_password
#   - langfuse-s3: event_upload_access_key_id, event_upload_secret_access_key,
#       media_upload_access_key_id, media_upload_secret_access_key,
#       batch_export_access_key_id, batch_export_secret_access_key
#   - langfuse-init: org_id, org_name, project_id, project_name,
#       project_public_key, project_secret_key, user_email, user_name, user_password
# =============================================================================

# =============================================================================
# PostgreSQL
# =============================================================================
DATABASE_URL={{ infisical:///database_url }}
POSTGRES_USER={{ infisical:///postgres_user }}
POSTGRES_PASSWORD={{ infisical:///postgres_password }}

# =============================================================================
# Application Secrets
# =============================================================================
SALT={{ infisical:///salt }}
ENCRYPTION_KEY={{ infisical:///encryption_key }}
NEXTAUTH_SECRET={{ infisical:///nextauth_secret }}

# =============================================================================
# ClickHouse
# =============================================================================
CLICKHOUSE_USER={{ infisical:///clickhouse_user }}
CLICKHOUSE_PASSWORD={{ infisical:///clickhouse_password }}

# =============================================================================
# Redis
# =============================================================================
REDIS_AUTH={{ infisical:///redis_auth }}

# =============================================================================
# MinIO (S3-compatible storage)
# =============================================================================
MINIO_ROOT_USER={{ infisical:///minio_root_user }}
MINIO_ROOT_PASSWORD={{ infisical:///minio_root_password }}

# =============================================================================
# S3 Event Upload
# =============================================================================
LANGFUSE_S3_EVENT_UPLOAD_ACCESS_KEY_ID={{ infisical:///event_upload_access_key_id }}
LANGFUSE_S3_EVENT_UPLOAD_SECRET_ACCESS_KEY={{ infisical:///event_upload_secret_access_key }}

# =============================================================================
# S3 Media Upload
# =============================================================================
LANGFUSE_S3_MEDIA_UPLOAD_ACCESS_KEY_ID={{ infisical:///media_upload_access_key_id }}
LANGFUSE_S3_MEDIA_UPLOAD_SECRET_ACCESS_KEY={{ infisical:///media_upload_secret_access_key }}

# =============================================================================
# S3 Batch Export
# =============================================================================
LANGFUSE_S3_BATCH_EXPORT_ACCESS_KEY_ID={{ infisical:///batch_export_access_key_id }}
LANGFUSE_S3_BATCH_EXPORT_SECRET_ACCESS_KEY={{ infisical:///batch_export_secret_access_key }}

# =============================================================================
# Langfuse Init (first-run bootstrap)
# =============================================================================
LANGFUSE_INIT_ORG_ID={{ infisical:///init_org_id }}
LANGFUSE_INIT_ORG_NAME={{ infisical:///init_org_name }}
LANGFUSE_INIT_PROJECT_ID={{ infisical:///init_project_id }}
LANGFUSE_INIT_PROJECT_NAME={{ infisical:///init_project_name }}
LANGFUSE_INIT_PROJECT_PUBLIC_KEY={{ infisical:///init_project_public_key }}
LANGFUSE_INIT_PROJECT_SECRET_KEY={{ infisical:///init_project_secret_key }}
LANGFUSE_INIT_USER_EMAIL={{ infisical:///init_user_email }}
LANGFUSE_INIT_USER_NAME={{ infisical:///init_user_name }}
LANGFUSE_INIT_USER_PASSWORD={{ infisical:///init_user_password }}