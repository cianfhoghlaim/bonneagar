# =============================================================================
# GRAPHITI - Locket Secrets Template (dev-baile vault)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
#
# Updated for the `centralise-data-plane` rewrite (2026-07-30):
# - The Neo4j backend was removed (no Neo4j stack in KCG).
# - FALKORDB_PASSWORD is resolved from the shared falkordb vault.
# - OPENAI_API_KEY stays (graphiti uses it for entity extraction via
#   the LLM provider; canonical backbone is Bolmo / Molmo2 / Qwen3-VL
#   via LiteLLM).
# =============================================================================

# FalkorDB (shared with the falkordb stack)
FALKORDB_PASSWORD=infisical://dev-baile/falkordb/password

# Graphiti-specific
OPENAI_API_KEY=infisical://dev-baile/graphiti/openai_api_key
FALKORDB_GRAPHITI_DB=infisical://dev-baile/graphiti/falkordb_database
