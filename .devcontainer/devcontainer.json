{
    "name": "Python Dev Environment",
    "build": "Dockerfile",
    "customizations": {
        "vscode": {
            "extensions": [
                "charliermarsh.ruff",
                "kevinrose.vsc-python-indent",
                "ms-python.python",
                "marimo-team.vscode-marimo",
            ]
        }
    },
    "containerEnv": {
        "DISPLAY": "dummy",
        "PYTHONUNBUFFERED": "True",
        "UV_LINK_MODE": "copy",
        "UV_PROJECT_ENVIRONMENT": "/home/vscode/.venv"
    },
    "postStartCommand": "uv sync"
}