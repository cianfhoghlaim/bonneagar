# =============================================================================
# KOMODO PERIPHERY CONFIGURATION
# =============================================================================
# Generated by Ansible - Do not edit manually
# Template: periphery.config.toml.j2
# =============================================================================

{% if periphery_mode == 'outbound' and periphery_core_address %}
# -----------------------------------------------------------------------------
# CORE CONNECTION (Outbound Mode)
# -----------------------------------------------------------------------------
[core]
address = "{{ periphery_core_address }}"

{% endif %}
# -----------------------------------------------------------------------------
# AUTHENTICATION
# -----------------------------------------------------------------------------
{% if periphery_passkeys | length > 0 %}
passkeys = [
{% for key in periphery_passkeys %}
  "{{ key }}",
{% endfor %}
]
{% else %}
passkeys = []
{% endif %}

# -----------------------------------------------------------------------------
# SERVER CONFIGURATION
# -----------------------------------------------------------------------------
[server]
port = {{ periphery_port }}
bind = "{{ periphery_bind_address }}"

# -----------------------------------------------------------------------------
# SSL/TLS
# -----------------------------------------------------------------------------
[ssl]
enabled = {{ periphery_ssl_enabled | lower }}
{% if periphery_ssl_cert_path %}
cert_path = "{{ periphery_ssl_cert_path }}"
{% endif %}
{% if periphery_ssl_key_path %}
key_path = "{{ periphery_ssl_key_path }}"
{% endif %}

# -----------------------------------------------------------------------------
# FEATURES
# -----------------------------------------------------------------------------
[features]
disable_terminals = {{ periphery_disable_terminals | lower }}

# -----------------------------------------------------------------------------
# DOCKER
# -----------------------------------------------------------------------------
[docker]
socket = "{{ periphery_docker_socket }}"

# -----------------------------------------------------------------------------
# STATS & MONITORING
# -----------------------------------------------------------------------------
[stats]
refresh_ms = {{ periphery_stats_refresh_ms }}

# -----------------------------------------------------------------------------
# DISK MOUNTS
# -----------------------------------------------------------------------------
{% if periphery_include_disk_mounts %}
include_disk_mounts = "{{ periphery_include_disk_mounts }}"
{% endif %}
{% if periphery_exclude_disk_mounts %}
exclude_disk_mounts = "{{ periphery_exclude_disk_mounts }}"
{% endif %}

# -----------------------------------------------------------------------------
# IP ALLOWLIST
# -----------------------------------------------------------------------------
{% if periphery_allowed_ips | length > 0 %}
allowed_ips = [
{% for ip in periphery_allowed_ips %}
  "{{ ip }}",
{% endfor %}
]
{% endif %}
