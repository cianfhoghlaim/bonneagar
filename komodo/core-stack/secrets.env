# =============================================================================
# KOMODO CORE - Locket Secrets Template
# =============================================================================
# Resolved by Locket at runtime via Infisical
# Vault: dev-baile

# Database credentials
KOMODO_DATABASE_USERNAME={{ infisical:///database_username }}
KOMODO_DATABASE_PASSWORD={{ infisical:///database_password }}

# Security secrets
KOMODO_JWT_SECRET={{ infisical:///jwt-secret }}
KOMODO_PASSKEY={{ infisical:///passkey }}
KOMODO_WEBHOOK_SECRET={{ infisical:///webhook-secret }}

# Admin initialization
KOMODO_INIT_ADMIN_USERNAME={{ infisical:///username }}
KOMODO_INIT_ADMIN_PASSWORD={{ infisical:///password }}

# OIDC Authentication (PocketID)
KOMODO_OIDC_ENABLED=true
KOMODO_OIDC_PROVIDER=https://auth.cianfhoghlaim.ie
KOMODO_OIDC_CLIENT_ID={{ infisical:///client_id }}
KOMODO_OIDC_CLIENT_SECRET={{ infisical:///client_secret }}
