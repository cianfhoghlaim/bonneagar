# =============================================================================
# COGNEE - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses 1Password Connect references (op://vault/item/field).
#
# USAGE:
#   locket exec --provider op-connect \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
# =============================================================================

# PostgreSQL
DB_USERNAME={{ op://taisce-secrets/cognee-postgres/username }}
DB_PASSWORD={{ op://taisce-secrets/cognee-postgres/password }}
DB_NAME={{ op://taisce-secrets/cognee-postgres/database }}

# Memgraph
MEMGRAPH_USER={{ op://taisce-secrets/cognee-memgraph/username }}
MEMGRAPH_PASSWORD={{ op://taisce-secrets/cognee-memgraph/password }}

# LLM API Keys
LLM_API_KEY={{ op://taisce-secrets/cognee-llm/api_key }}
EMBEDDING_API_KEY={{ op://taisce-secrets/cognee-llm/embedding_api_key }}
