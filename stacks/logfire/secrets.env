# Pydantic Logfire Configuration
# OpenTelemetry-based observability for Python applications.
#
# This stack uses an OpenTelemetry Collector (compose.yaml) to receive OTLP
# traces from KCG services and forward them to Logfire cloud. The
# LOGFIRE_TOKEN below is the project write token from logfire.pydantic.dev.
#
# Docs: https://logfire.pydantic.dev/docs/

LOGFIRE_TOKEN=infisical://dev-baile/logfire/write_token
LOGFIRE_PROJECT_NAME=oideachas-celtic-education
LOGFIRE_SERVICE_NAME=education-pipeline

# Optional: Environment tagging (consumed by the otelcol processor + exported
# as a resource attribute so the Logfire UI groups traces by environment).
LOGFIRE_ENVIRONMENT=production

# Application code that wants to send traces via OTLP instead of the SDK
# should point at the local collector:
#   OTEL_EXPORTER_OTLP_ENDPOINT=http://logfire-otel:4317
# (host.docker.internal works from a host-side process; logfire-otel is the
# in-network hostname from the compose service name).
