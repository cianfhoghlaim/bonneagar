# =============================================================================
# STIRLING-PDF - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# NOTE: Stirling-PDF compose.yaml currently has SECURITY_ENABLELOGIN=false.
# When enabling authentication, set the following secrets.
# =============================================================================

# =============================================================================
# Security (enable when ready to add login requirement)
# =============================================================================
# SECURITY_ENABLELOGIN=true
# SECURITY_LOGIN_ATTEMPT_COUNT=5
# SECURITY_LOGIN_RESET_TIME=30m

# =============================================================================
# API Key (for PRO/LOCAL customization features)
# =============================================================================
# API_KEY={{ infisical:///api_key }}