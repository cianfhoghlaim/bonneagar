# =============================================================================
# COGNEE - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical://vault/item/field).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
# =============================================================================

# PostgreSQL
DB_USERNAME={{ infisical:///username }}
DB_PASSWORD={{ infisical:///password }}
DB_NAME={{ infisical:///database }}

# Memgraph
MEMGRAPH_USER={{ infisical:///username }}
MEMGRAPH_PASSWORD={{ infisical:///password }}

# LLM API Keys
LLM_API_KEY={{ infisical:///api_key }}
EMBEDDING_API_KEY={{ infisical:///embedding_api_key }}
