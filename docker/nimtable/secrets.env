# =============================================================================
# NIMTABLE - Locket Secrets Template
# =============================================================================

# PostgreSQL
NIMTABLE_DB_USER={{ op://taisce-secrets/nimtable-postgres/username }}
NIMTABLE_DB_PASSWORD={{ op://taisce-secrets/nimtable-postgres/password }}

# S3/R2 Storage
AWS_ACCESS_KEY_ID={{ op://taisce-secrets/cloudflare-r2/access_key_id }}
AWS_SECRET_ACCESS_KEY={{ op://taisce-secrets/cloudflare-r2/secret_access_key }}
AWS_ENDPOINT_URL={{ op://taisce-secrets/cloudflare-r2/endpoint_url }}
