# =============================================================================
# CONVEX - Locket Exec Mode Secrets Template
# =============================================================================
# Used with: locket exec --env-file secrets.env -- docker compose up -d
# =============================================================================

# Instance secrets
CONVEX_INSTANCE_SECRET={{ op://taisce-secrets/convex/instance_secret }}

# S3/R2 storage (optional - for production file storage)
AWS_ACCESS_KEY_ID={{ op://taisce-secrets/convex-s3/access_key_id }}
AWS_SECRET_ACCESS_KEY={{ op://taisce-secrets/convex-s3/secret_access_key }}
AWS_ENDPOINT_URL={{ op://taisce-secrets/convex-s3/endpoint_url }}

# Database URL (optional - for external database)
CONVEX_POSTGRES_URL={{ op://taisce-secrets/convex-postgres/connection_url }}
