# =============================================================================
# NEWT Hetzner - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
#
# PREREQUISITES:
#   1. Create site "cax41-hetzner" in Pangolin UI (Sites -> Create Site -> Newt)
#   2. Copy the ID and Secret from the site creation dialog
#   3. Create 1Password item:
#      op item create --vault dev-baile --title "cax41-hetzner-newt" \
#        id="<newt_id>" secret="<newt_secret>"
#
# USAGE:
#   docker compose -f compose.yaml -f sidecar.yaml up -d
# =============================================================================

# Newt Credentials (from Pangolin site creation)
NEWT_ID={{ op://dev-baile/cax41-hetzner-newt/id }}
NEWT_SECRET={{ op://dev-baile/cax41-hetzner-newt/secret }}
