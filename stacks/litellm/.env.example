# =============================================================================
# LITELLM - Environment Variable Catalogue
# =============================================================================
# Documents every ${VAR} reference in litellm/compose.yaml.
#
# USAGE:
#   For local dev: cp .env.example .env, edit, then
#     `docker compose -f compose.yaml -f compose.dev.yaml -f sidecar.yaml up -d`
#   For production: rely on Locket (no .env needed).
#
# The litellm stack assumes lakehouse-bunchloch is already up with the
# centralised data plane (postgres + garage). The `litellm` database
# is auto-created by lakehouse/init-db.sql. See
# stedding/docs/stacks/litellm.md for the integration contract.
# =============================================================================

# =============================================================================
# LiteLLM Gateway (real keys come from Locket; dev fallbacks below)
# =============================================================================
LITELLM_MASTER_KEY=sk-dev-placeholder
LITELLM_SALT_KEY=sk-salt-dev-placeholder

# Centralised postgres (from lakehouse/* vault; resolved via Locket at runtime)
# Dev fallbacks below for local `.env`.
POSTGRES_USER=lakekeeper
POSTGRES_PASSWORD=devpassword-change-me
AWS_ACCESS_KEY_ID=lakehouse
AWS_SECRET_ACCESS_KEY=devpassword-change-me

# =============================================================================
# Cloud providers (real keys come from Locket)
# =============================================================================
# GEMINI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# OPENCODE_GO_API_KEY=
# HF_TOKEN=

# =============================================================================
# Observability endpoints (URLs; auth comes from Locket)
# =============================================================================
LANGFUSE_HOST=https://langfuse.cianfhoghlaim.ie
MLFLOW_TRACKING_URI=http://mlflow:5000

# =============================================================================
# Feature flags
# =============================================================================
USE_GEMINI_3=false
LITELLM_LOG=INFO

# =============================================================================
# Infisical + Locket
# =============================================================================
INFISICAL_URL=http://132.145.27.89:8080
# INFISICAL_CLIENT_ID=<machine identity>
# INFISICAL_SECRET_FILE=./infisical_secret
LOCKET_MODE=watch
