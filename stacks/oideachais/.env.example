# Oideachais — Local dev placeholder env vars
# COMMITTED: yes. This file is for local development only.
# For production, Locket resolves secrets via Infisical.

# LLM Gateway
LLM_API_KEY=sk-1234  # pragma: allowlist secret
LITELLM_MASTER_KEY=sk-1234  # pragma: allowlist secret

# Storage
R2_ACCESS_KEY=dev-access-key
R2_SECRET_KEY=dev-secret-key  # pragma: allowlist secret
MOTHERDUCK_TOKEN=dev-token  # pragma: allowlist secret

# SEC Scraping
FIRECRAWL_API_KEY=fc-dev-key  # pragma: allowlist secret
BROWSERBASE_API_KEY=bb-dev-key  # pragma: allowlist secret
BROWSERBASE_PROJECT_ID=dev-project

# OpenCode Go
OPENCODE_GO_API_KEY=oc-dev-key  # pragma: allowlist secret

# Better Auth
BETTER_AUTH_SECRET=dev-secret-32-byte-hex  # pragma: allowlist secret
BETTER_AUTH_URL=http://localhost:3000

# Observability
LANGFUSE_PUBLIC_KEY=pk-dev
LANGFUSE_SECRET_KEY=sk-dev  # pragma: allowlist secret
MLFLOW_TRACKING_URI=http://localhost:5000
