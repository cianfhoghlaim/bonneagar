# Frontend stack dev-only env vars (no secrets here)
# These are loaded by `docker compose --env-file .env` in dev only.
# Production secrets come from Infisical via the Locket sidecar.

NODE_ENV=development

# Service ports
OIDEACHAIS_WEB_PORT=3001
OIDEACHAIS_API_PORT=8787
TUATHA_UI_PORT=3004
CROILAR_WEB_PORT=3003
CROILAR_PORTAL_PORT=3000

# Service URLs (dev defaults — production uses Infisical)
VITE_CONVEX_URL=http://localhost:3210
VITE_HONO_API_URL=http://localhost:4000
VITE_AUTH_URL=http://localhost:4000
CONVEX_HTTP_URL=http://localhost:3210
LITELLM_BASE_URL=http://localhost:4000

# Public-facing URLs
PUBLIC_WEB_URL=http://localhost:3003
PUBLIC_AUTH_URL=http://localhost:4000
BETTER_AUTH_URL=http://localhost:4000
CORS_ORIGIN=http://localhost:3001

# Model config
PORTAL_AGENT_MODEL=deepseek/deepseek-chat

# Backend connection URLs
GRAPHITI_MCP_URL=http://localhost:8080
LANCEDB_MCP_URL=http://localhost:8080
LANGFUSE_HOST=http://localhost:3000
PROJECT_ROOT=/portal-src
