# =============================================================================
# CROILAR-POSTGRES — Local Dev Database Secrets
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile/croilar/postgres/:
#   username, password, database
# =============================================================================

# Croílár dev Postgres
POSTGRES_USER={{ infisical:///croilar/postgres/username }}
POSTGRES_PASSWORD={{ infisical:///croilar/postgres/password }}
POSTGRES_DB={{ infisical:///croilar/postgres/database }}
