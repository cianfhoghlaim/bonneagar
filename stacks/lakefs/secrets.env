# =============================================================================
# LAKEFS - Locket Secrets Template
# =============================================================================

# PostgreSQL
LAKEFS_DB_USERNAME={{ infisical:///username }}
LAKEFS_DB_PASSWORD={{ infisical:///password }}

# Authentication
LAKEFS_AUTH_ENCRYPT_SECRET_KEY={{ infisical:///secret_key }}

# MinIO
MINIO_ROOT_USER={{ infisical:///username }}
MINIO_ROOT_PASSWORD={{ infisical:///password }}
