# =============================================================================
# GRAPHITI - Locket Secrets Template
# =============================================================================
# All values are Locket-canonical `infisical://dev-baile/<svc>/<key>` URIs
# resolved at container start by the Locket sidecar (see sidecar.yaml).
# Migrated from the legacy Jinja `{{ infisical:///... }}` form by the
# `consolidate-observability-and-graph` openspec change (2026-06-26).
# =============================================================================

# =============================================================================
# LLM Provider (used by graph and graph-falkordb services)
# =============================================================================
OPENAI_API_KEY=infisical://dev-baile/graphiti/openai_api_key

# =============================================================================
# Neo4j
# =============================================================================
NEO4J_USER=infisical://dev-baile/graphiti/neo4j_user
NEO4J_PASSWORD=infisical://dev-baile/graphiti/neo4j_password
