# =============================================================================
# NEWT - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Update the Infisical references to match your vault/item names.
#
# USAGE:
#   docker compose -f newt.compose.yaml -f newt.sidecar.yaml up -d
# =============================================================================

# Newt Credentials (from Pangolin site creation)
NEWT_ID={{ infisical:///id }}
NEWT_SECRET={{ infisical:///secret }}
