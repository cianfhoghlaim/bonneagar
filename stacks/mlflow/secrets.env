# =============================================================================
# MLFLOW - Locket Secrets Template
# =============================================================================
# All values are Locket-canonical `infisical://dev-baile/<svc>/<key>` URIs
# resolved at container start by the Locket sidecar (see sidecar.yaml).
# Migrated from the legacy Jinja `{{ infisical:///... }}` form by the
# `consolidate-observability-and-graph` openspec change (2026-06-26).
# =============================================================================

# PostgreSQL
POSTGRES_USER=infisical://dev-baile/mlflow/username
POSTGRES_PASSWORD=infisical://dev-baile/mlflow/password
POSTGRES_DB=infisical://dev-baile/mlflow/database

# MinIO
MINIO_ROOT_USER=infisical://dev-baile/mlflow/username
MINIO_ROOT_PASSWORD=infisical://dev-baile/mlflow/password
