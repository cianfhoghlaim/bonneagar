# =============================================================================
# ROMM - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - romm-mariadb: db_root_passwd, db_passwd
#   - romm-postgres: postgres_password
#   - romm-authentik: authentik_secret_key, authentik_bootstrap_password
# =============================================================================

# =============================================================================
# MariaDB (Game Library Database)
# =============================================================================
MARIADB_ROOT_PASSWORD={{ infisical:///db_root_passwd }}
MARIADB_DATABASE=romm
MARIADB_USER=romm
MARIADB_PASSWORD={{ infisical:///db_passwd }}

# =============================================================================
# PostgreSQL (Authentik Backend)
# =============================================================================
POSTGRES_PASSWORD={{ infisical:///postgres_password }}
POSTGRES_USER=postgres
POSTGRES_DB=authentik

# =============================================================================
# Authentik (SSO / Identity Provider)
# =============================================================================
AUTHENTIK_SECRET_KEY={{ infisical:///authentik_secret_key }}
AUTHENTIK_BOOTSTRAP_PASSWORD={{ infisical:///authentik_bootstrap_password }}