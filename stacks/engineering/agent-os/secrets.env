# =============================================================================
# AGENT-OS - Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   agent-os/  agent_os_secret_key, x402_pay_to_address, oideachais_db_url,
#              crypteolas_db_url, browser_db_url, croilar_db_url
# =============================================================================

# Shared A2A secret (used by all 4 agents for cross-flow authentication)
AGENT_OS_SECRET_KEY={{ infisical:///agent-os/agent_os_secret_key }}

# x402 micropayment receiving address (crypteolas only, but kept here for symmetry)
X402_PAY_TO_ADDRESS={{ infisical:///agent-os/x402_pay_to_address }}

# Optional per-agent database URLs (default to local SQLite)
OIDEACHAIS_DB_URL={{ infisical:///agent-os/oideachais_db_url }}
CRYPTEOLAS_DB_URL={{ infisical:///agent-os/crypteolas_db_url }}
BROWSER_DB_URL={{ infisical:///agent-os/browser_db_url }}
CROILAR_DB_URL={{ infisical:///agent-os/croilar_db_url }}
