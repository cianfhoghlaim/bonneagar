# =============================================================================
# LAKEHOUSE - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses 1Password Connect references (op://vault/item/field).
#
# USAGE:
#   locket exec --provider op-connect \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# 1PASSWORD VAULT ITEMS TO CREATE:
#   - planetscale-lakehouse: database_url
#   - lakekeeper-auth: encryption_key
#   - lakehouse-garage: rpc_secret, admin_token, access_key_id, secret_access_key
# =============================================================================

# =============================================================================
# PlanetScale PostgreSQL (Shared by Lakekeeper and DuckLake)
# =============================================================================
# Connection URL format: postgresql://user:password@host:port/database?sslmode=require
PLANETSCALE_DATABASE_URL={{ op://taisce-secrets/planetscale-lakehouse/database_url }}

# =============================================================================
# Lakekeeper Configuration
# =============================================================================
# 64-character hex encryption key for Lakekeeper secrets storage
LAKEKEEPER_ENCRYPTION_KEY={{ op://taisce-secrets/lakekeeper-auth/encryption_key }}

# SSL mode for PlanetScale (should be 'require' for production)
LAKEKEEPER_SSL_MODE=require

# =============================================================================
# Garage S3 Storage
# =============================================================================
# RPC secret for internal Garage communication (64+ char random string)
GARAGE_RPC_SECRET={{ op://dev-baile/lakehouse-garage/rpc_secret }}

# Admin API token for Garage management
GARAGE_ADMIN_TOKEN={{ op://dev-baile/lakehouse-garage/admin_token }}

# S3 access credentials
GARAGE_ACCESS_KEY_ID={{ op://dev-baile/lakehouse-garage/access_key_id }}
GARAGE_SECRET_ACCESS_KEY={{ op://dev-baile/lakehouse-garage/secret_access_key }}

# =============================================================================
# Lance Namespace Sidecar (Optional)
# =============================================================================
# Auth token for Lakekeeper (if authentication is enabled)
# LANCE_ICEBERG_AUTH_TOKEN={{ op://taisce-secrets/lakekeeper-auth/service_token }}

# =============================================================================
# Cloudflare R2 (Remote Object Storage)
# =============================================================================
# S3-compatible cloud storage for production deployments
R2_ACCESS_KEY_ID={{ op://taisce-secrets/cloudflare-r2/access_key_id }}
R2_SECRET_ACCESS_KEY={{ op://taisce-secrets/cloudflare-r2/secret_access_key }}
R2_ACCOUNT_ID={{ op://taisce-secrets/cloudflare-r2/account_id }}
R2_BUCKET_NAME=lakehouse

# =============================================================================
# MotherDuck (Remote Query Engine)
# =============================================================================
# Cloud-hosted DuckDB for production analytics
MOTHERDUCK_TOKEN={{ op://taisce-secrets/motherduck/token }}
