# =============================================================================
# LITELLM GATEWAY — Locket Secrets Template (dev-baile vault)
# =============================================================================
# COMMITTED: yes. PLAINTEXT: NEVER.
# Resolved at container runtime by the Locket sidecar.
# =============================================================================

# Gateway
LITELLM_MASTER_KEY=infisical://dev-baile/litellm/master_key
LITELLM_SALT_KEY=infisical://dev-baile/litellm/salt_key

# Gateway Postgres (separate from lakehouse; holds model registry)
LITELLM_DATABASE_URL=infisical://dev-baile/litellm/database_url
LITELLM_POSTGRES_USER=infisical://dev-baile/litellm/postgres_user
LITELLM_POSTGRES_PASSWORD=infisical://dev-baile/litellm/postgres_password
LITELLM_POSTGRES_DB=infisical://dev-baile/litellm/postgres_db

# Cloud LLM providers
DEEPSEEK_API_KEY=infisical://dev-baile/deepseek/api_key
GEMINI_API_KEY=infisical://dev-baile/gemini/api_key
ANTHROPIC_API_KEY=infisical://dev-baile/anthropic/api_key
OPENAI_API_KEY=infisical://dev-baile/openai/api_key
Z_AI_API_KEY=infisical://dev-baile/zai/api_key
ZAI_API_KEY=infisical://dev-baile/zai/api_key
# OpenCode Go — canonical key + 3 parallel slots for the `minimax`
# alias round-robin (see config.yaml fallback_chain). Each slot is a
# distinct credential so 5-hour rolling caps are independent.
OPENCODE_GO_API_KEY=infisical://dev-baile/opencode-go/api_key
OPENCODE_GO_API_KEY_0=infisical://dev-baile/opencode-go/api_key_slot0
OPENCODE_GO_API_KEY_1=infisical://dev-baile/opencode-go/api_key_slot1
OPENCODE_GO_API_KEY_2=infisical://dev-baile/opencode-go/api_key_slot2

# HuggingFace
HF_TOKEN=infisical://dev-baile/huggingface/token
HUGGINGFACE_HUB_TOKEN=infisical://dev-baile/huggingface/token
HUGGINGFACE_TOKEN=infisical://dev-baile/huggingface/token

# Observability (consumers)
LANGFUSE_HOST=infisical://dev-baile/langfuse/host
LANGFUSE_PUBLIC_KEY=infisical://dev-baile/langfuse/public_key
LANGFUSE_SECRET_KEY=infisical://dev-baile/langfuse/secret_key
MLFLOW_TRACKING_URI=infisical://dev-baile/mlflow/uri
LANCEDB_API_KEY=infisical://dev-baile/lancedb/api_key
