# =============================================================================
# LANGFUSE - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical://vault/item/field).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
# =============================================================================

# PostgreSQL
POSTGRES_USER={{ infisical:///username }}
POSTGRES_PASSWORD={{ infisical:///password }}
POSTGRES_DB={{ infisical:///database }}

# ClickHouse
CLICKHOUSE_USER={{ infisical:///username }}
CLICKHOUSE_PASSWORD={{ infisical:///password }}

# Redis
REDIS_AUTH={{ infisical:///password }}

# MinIO
MINIO_ROOT_USER={{ infisical:///username }}
MINIO_ROOT_PASSWORD={{ infisical:///password }}

# Authentication
NEXTAUTH_SECRET={{ infisical:///nextauth_secret }}
SALT={{ infisical:///salt }}
ENCRYPTION_KEY={{ infisical:///encryption_key }}
