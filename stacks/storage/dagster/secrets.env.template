# Dagster Secrets Template
# Copy to secrets.env and fill in values

# DuckLake PostgreSQL (from lakehouse)
DUCKLAKE_POSTGRES_PASSWORD={{ infisical:///POSTGRES_PASSWORD }}

# Garage S3 (from lakehouse)
AWS_ACCESS_KEY_ID={{ infisical:///GARAGE_ACCESS_KEY }}
AWS_SECRET_ACCESS_KEY={{ infisical:///GARAGE_SECRET_KEY }}

# LLM API Keys
ANTHROPIC_API_KEY={{ infisical:///CREDENTIAL }}
OPENAI_API_KEY={{ infisical:///CREDENTIAL }}

# Langfuse Observability
LANGFUSE_PUBLIC_KEY={{ infisical:///PUBLIC_KEY }}
LANGFUSE_SECRET_KEY={{ infisical:///SECRET_KEY }}
