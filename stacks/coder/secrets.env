# =============================================================================
# CODER - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///<SECRET_KEY>).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - coder-postgres: user, password, db
#   - coder-app: access_url
# =============================================================================

# =============================================================================
# PostgreSQL Database
# =============================================================================
POSTGRES_USER={{ infisical:///user }}
POSTGRES_PASSWORD={{ infisical:///password }}
POSTGRES_DB={{ infisical:///db }}

# =============================================================================
# Coder Application
# =============================================================================
# External URL that workspaces can reach (cannot be localhost/127.0.0.1)
CODER_ACCESS_URL={{ infisical:///access_url }}