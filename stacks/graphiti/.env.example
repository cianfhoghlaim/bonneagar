# =============================================================================
# GRAPHITI - Environment Variable Catalogue
# =============================================================================
# Documents every ${VAR} reference in graphiti/compose.yaml.
# Most values are resolved at runtime by Locket from infisical://
# URIs declared in secrets.env.
#
# USAGE:
#   docker compose -f compose.yaml -f sidecar.yaml up -d
#   # Locket injects the secrets at container runtime.
# =============================================================================

GRAPHITI_PORT=8000
FALKORDB_PORT=6379
# FALKORDB_GRAPHITI_DB=default_db
# FALKORDB_PASSWORD + OPENAI_API_KEY: real values come from
# infisical://dev-baile/{falkordb,graphiti}/* via Locket at runtime.
# Dev fallbacks (so `docker compose config --quiet` passes locally):
FALKORDB_PASSWORD=devpassword
OPENAI_API_KEY=sk-dev-placeholder

# =============================================================================
# Infisical + Locket
# =============================================================================
# INFISICAL_URL=http://132.145.27.89:8080
# INFISICAL_CLIENT_ID=<machine identity>
# INFISICAL_SECRET_FILE=./infisical_secret
LOCKET_MODE=watch
