# =============================================================================
# OLM - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Update the Infisical references to match your vault/item names.
#
# USAGE:
#   docker compose -f olm.compose.yaml -f olm.sidecar.yaml up -d
# =============================================================================

# OLM Credentials (from Pangolin site creation)
OLM_ID={{ infisical:///id }}
OLM_SECRET={{ infisical:///secret }}
