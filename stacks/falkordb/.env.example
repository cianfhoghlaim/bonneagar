# =============================================================================
# FALKORDB - Environment Variable Catalogue
# =============================================================================
# Documents every ${VAR} reference in falkordb/compose.yaml.
# Most values are resolved at runtime by Locket from infisical://
# URIs declared in secrets.env.
#
# USAGE:
#   docker compose -f compose.yaml -f sidecar.yaml up -d
#   # Locket injects the secrets at container runtime.
# =============================================================================

FALKORDB_PORT=6379
FALKORDB_UI_PORT=3000
# FALKORDB_PASSWORD: real value comes from
# infisical://dev-baile/falkordb/password via Locket at runtime.
# Dev fallback (so `docker compose config --quiet` passes locally):
FALKORDB_PASSWORD=devpassword
FALKORDB_BROWSER=1

# =============================================================================
# Infisical + Locket
# =============================================================================
# INFISICAL_URL=http://132.145.27.89:8080
# INFISICAL_CLIENT_ID=<machine identity>
# INFISICAL_SECRET_FILE=./infisical_secret
LOCKET_MODE=watch
