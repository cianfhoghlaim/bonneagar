# =============================================================================
# NIMTABLE - Locket Secrets Template
# =============================================================================

# PostgreSQL
NIMTABLE_DB_USER={{ infisical:///username }}
NIMTABLE_DB_PASSWORD={{ infisical:///password }}

# S3/R2 Storage
AWS_ACCESS_KEY_ID={{ infisical:///access_key_id }}
AWS_SECRET_ACCESS_KEY={{ infisical:///secret_access_key }}
AWS_ENDPOINT_URL={{ infisical:///endpoint_url }}
