# =============================================================================
# LANGFUSE - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=devpassword
POSTGRES_DB=langfuse

# =============================================================================
# ClickHouse
# =============================================================================
CLICKHOUSE_USER=clickhouse
CLICKHOUSE_PASSWORD=devpassword

# =============================================================================
# Redis
# =============================================================================
REDIS_AUTH=devpassword

# =============================================================================
# MinIO (S3-compatible storage)
# =============================================================================
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=devpassword

# =============================================================================
# Langfuse Application
# =============================================================================
LANGFUSE_PORT=3000
LANGFUSE_LOG_LEVEL=info
NEXTAUTH_URL=http://localhost:3000

# =============================================================================
# Secrets (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# POSTGRES_PASSWORD=<strong-password>              # Set via Locket/Infisical in production
# CLICKHOUSE_PASSWORD=<strong-password>             # Set via Locket/Infisical in production
# REDIS_AUTH=<strong-password>                      # Set via Locket/Infisical in production
# MINIO_ROOT_PASSWORD=<strong-password>              # Set via Locket/Infisical in production
# NEXTAUTH_SECRET=<random-secret>                    # Set via Locket/Infisical in production
# SALT=<random-salt>                                 # Set via Locket/Infisical in production
# ENCRYPTION_KEY=<64-char-hex-key>                  # Set via Locket/Infisical in production