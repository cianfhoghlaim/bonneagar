# =============================================================================
# RYBBIT - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - rybbit-postgres: postgres_user, postgres_password
#   - rybbit-clickhouse: clickhouse_password
#   - rybbit: better_auth_secret, mapbox_token
# =============================================================================

# =============================================================================
# PostgreSQL
# =============================================================================
POSTGRES_USER=frog
POSTGRES_PASSWORD={{ infisical:///postgres_password }}

# =============================================================================
# ClickHouse
# =============================================================================
CLICKHOUSE_PASSWORD={{ infisical:///clickhouse_password }}

# =============================================================================
# Application Secrets
# =============================================================================
BETTER_AUTH_SECRET={{ infisical:///better_auth_secret }}

# =============================================================================
# External API Keys
# =============================================================================
MAPBOX_TOKEN={{ infisical:///mapbox_token }}

# =============================================================================
# Configuration (non-secret, set as needed)
# =============================================================================
DOMAIN_NAME=rybbit.cianfhoghlaim.ie
BASE_URL=https://rybbit.cianfhoghlaim.ie
DISABLE_SIGNUP=false
DISABLE_TELEMETRY=true