CALCOM_DB_PASSWORD={{ infisical:///db_password?path=/calcom }}
CALCOM_NEXTAUTH_SECRET={{ infisical:///nextauth_secret?path=/calcom }}
CALCOM_ENCRYPTION_KEY={{ infisical:///encryption_key?path=/calcom }}
CALCOM_WEBHOOK_SECRET={{ infisical:///webhook_secret?path=/calcom }}
# OIDC / SSO (configured via cal.com admin UI: /settings/organizations/sso)
# Callback URL: https://calcom.cianfhoghlaim.ie/api/auth/oidc
POCKETID_TEAM_WORKFLOW_CLIENT_SECRET={{ infisical:///client_secret?path=/pocketid-team-workflow }}
DATABASE_URL=postgresql://{{ infisical:///username?path=/planetscale }}:{{ infisical:///password?path=/planetscale }}@eu-west-3.pg.psdb.cloud:5432/bunchloch?sslmode=require&options=-c%20search_path%3Dcalcom
FALLBACK_DATABASE_URL=postgresql://calcom:{{ infisical:///db_password?path=/calcom }}@infisical-db:5432/calcom
