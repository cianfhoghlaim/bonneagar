# =============================================================================
# KAFKA - Locket Secrets Template
# =============================================================================
# Resolved at runtime by Locket against the dev-baile Infisical project.
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   kafka/  sasl_user, sasl_password, cluster_id
# =============================================================================

# SASL/SCRAM credentials for the oideachais producer/consumer
KAFKA_SASL_USER={{ infisical:///kafka/sasl_user }}
KAFKA_SASL_PASSWORD={{ infisical:///kafka/sasl_password }}

# Kraft cluster ID (must match compose.yaml KAFKA_KRAFT_CLUSTER_ID)
KAFKA_CLUSTER_ID={{ infisical:///kafka/cluster_id }}
