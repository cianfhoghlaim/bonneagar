# =============================================================================
# MLFLOW - Environment Variable Catalogue
# =============================================================================
# Documents every ${VAR} reference in mlflow/compose.yaml.
#
# USAGE:
#   For local dev: cp .env.example .env, edit, then
#     `docker compose -f compose.yaml -f sidecar.yaml up -d`
#   For production: rely on Locket (no .env needed).
#
# The mlflow stack assumes lakehouse-bunchloch is already up with the
# centralised data plane (postgres + garage). The `mlflow` database and
# `mlflow-artifacts` bucket are auto-created. See
# stedding/docs/stacks/mlflow.md for the integration contract.
# =============================================================================

MLFLOW_PORT=5000

# =============================================================================
# Centralised data plane (resolved from lakehouse-* vaults via Locket)
# =============================================================================
# Real values come from the lakehouse/* and lakehouse-garage/* vaults
# at runtime via Locket. The dev values below allow
# `docker compose config --quiet` to pass locally.
POSTGRES_USER=lakekeeper
POSTGRES_PASSWORD=devpassword
GARAGE_ACCESS_KEY_ID=lakehouse
GARAGE_SECRET_ACCESS_KEY=devpassword

# Override for development only
# AWS_DEFAULT_REGION=garage

# Optional — defaults to s3://mlflow-artifacts/ when unset
# MLFLOW_DEFAULT_ARTIFACT_ROOT=s3://mlflow-artifacts/

# =============================================================================
# MLflow-specific secrets (resolved from mlflow/* vault)
# =============================================================================
# (currently empty — extend as needed)

# =============================================================================
# Infisical + Locket
# =============================================================================
# INFISICAL_URL=http://132.145.27.89:8080
# INFISICAL_CLIENT_ID=<machine identity>
# INFISICAL_SECRET_FILE=./infisical_secret
LOCKET_MODE=watch
