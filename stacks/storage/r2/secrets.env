# =============================================================================
# Cloudflare R2 Secrets
# =============================================================================
# Get credentials from: https://dash.cloudflare.com/[account-id]/r2/api-tokens
#
# Create R2 API Token with:
#   - Permission: Object Read & Write
#   - Scope: All buckets or specific buckets
# =============================================================================

R2_ACCOUNT_ID={{ infisical:///account_id }}
R2_ACCESS_KEY_ID={{ infisical:///access_key_id }}
R2_SECRET_ACCESS_KEY={{ infisical:///secret_access_key }}

# Mount point base directory
R2_MOUNT_BASE=/mnt/r2
