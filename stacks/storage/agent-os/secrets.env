# =============================================================================
# AGENT-OS SECRETS
# =============================================================================
# Template for AgentOS secrets. Use with locket for production.
#
# USAGE:
#   locket exec --env-file secrets.env -- docker compose up -d
#
# INFISICAL REFERENCES:
#   infisical://dev-baile/openai/credential
#   infisical://dev-baile/anthropic/credential
#   infisical://dev-baile/langfuse/public_key
#   infisical://dev-baile/langfuse/secret_key
#   infisical://dev-baile/x402-payment/pay_to_address
#   infisical://dev-baile/browserbase/api_key
#   infisical://dev-baile/browserbase/project_id
# =============================================================================

# -----------------------------------------------------------------------------
# AI Model API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY={{ infisical:///CREDENTIAL }}
ANTHROPIC_API_KEY={{ infisical:///CREDENTIAL }}

# Model Configuration
AGNO_DEFAULT_MODEL=gpt-4o
AGNO_CLAUDE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Service Authentication
# -----------------------------------------------------------------------------
# Shared secret for A2A service-to-service JWT signing
AGENT_OS_SECRET_KEY={{ infisical:///SECRET_KEY }}

# -----------------------------------------------------------------------------
# x402 Payment (Crypteolas only)
# -----------------------------------------------------------------------------
X402_ENABLED=true
X402_PAY_TO_ADDRESS={{ infisical:///PAY_TO_ADDRESS }}
X402_NETWORK=base
X402_SKIP_VERIFICATION=false

# -----------------------------------------------------------------------------
# Browser Backends
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY={{ infisical:///API_KEY }}
BROWSERBASE_PROJECT_ID={{ infisical:///PROJECT_ID }}
STAGEHAND_ENABLED=true
CRAWL4AI_ENABLED=true
SKYVERN_API_URL=
SKYVERN_API_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY={{ infisical:///PUBLIC_KEY }}
LANGFUSE_SECRET_KEY={{ infisical:///SECRET_KEY }}
LANGFUSE_HOST=https://langfuse.cianfhoghlaim.ie
AGNO_DEBUG=false

# -----------------------------------------------------------------------------
# Database URLs (optional, defaults to SQLite)
# -----------------------------------------------------------------------------
# OIDEACHAIS_DB_URL=postgresql://...
# CRYPTEOLAS_DB_URL=postgresql://...
# BROWSER_DB_URL=postgresql://...
# ALEYUM_DB_URL=postgresql://...

# -----------------------------------------------------------------------------
# Port Configuration
# -----------------------------------------------------------------------------
OIDEACHAIS_PORT=7772
CRYPTEOLAS_PORT=7771
BROWSER_PORT=7773
ALEYUM_PORT=7774
