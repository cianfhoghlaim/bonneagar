# =============================================================================
# LITELLM - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local
# Then: docker compose -f compose.yaml -f sidecar.yaml up -d
#
# All values that resolve to "infisical://dev-baile/..." URIs are populated
# at runtime by the Locket sidecar. Only put non-secret defaults here.
# =============================================================================

# =============================================================================
# LiteLLM Gateway (non-secret defaults; real keys come from Locket)
# =============================================================================
# Generate with: openssl rand -hex 32
LITELLM_MASTER_KEY=sk-dev-$(openssl rand -hex 24)
LITELLM_SALT_KEY=sk-salt-dev-$(openssl rand -hex 16)

# =============================================================================
# LiteLLM Postgres (separate from oideachais lakehouse DB)
# =============================================================================
LITELLM_POSTGRES_DB=litellm
LITELLM_POSTGRES_USER=llmproxy
LITELLM_POSTGRES_PASSWORD=devpassword-change-me
LITELLM_DATABASE_URL=postgresql://llmproxy:devpassword-change-me@db:5432/litellm

# =============================================================================
# Cloud providers (set in .env.local for dev, or via Locket/Infisical in prod)
# =============================================================================
# GEMINI_API_KEY=sk-...                     # Set via Locket/Infisical in production
# ANTHROPIC_API_KEY=sk-ant-...              # Set via Locket/Infisical in production
# OPENAI_API_KEY=sk-...                     # Set via Locket/Infisical in production
# Z_AI_API_KEY=...                          # Set via Locket/Infisical in production
# OPENCODE_GO_API_KEY=...                   # Set via Locket/Infisical in production
# HF_TOKEN=hf_...                           # Set via Locket/Infisical in production

# =============================================================================
# Feature flags
# =============================================================================
USE_GEMINI_3=false
LITELLM_LOG=INFO

# =============================================================================
# Observability (Langfuse)
# =============================================================================
# LANGFUSE_HOST=https://langfuse.cianfhoghlaim.ie
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...
# MLFLOW_TRACKING_URI=http://mlflow:5000
