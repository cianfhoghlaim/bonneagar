# Ansible Automation — Locket Secrets Template
# Vault: dev-baile
# These infisical:// references are resolved by Locket at runtime.
# The ansible container sources /run/secrets/locket/secrets.env on entry.

OCI_ARM1_IP={{ infisical://dev-baile/oci-infrastructure/arm1_ip }}
INFISICAL_CLIENT_SECRET={{ infisical://dev-baile/op_connect_cianfhoghlaim/credential }}
ANSIBLE_VAULT_PASSWORD={{ infisical://dev-baile/ansible/vault_password }}
