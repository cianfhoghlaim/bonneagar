# PostgreSQL
LAKEKEEPER_DB_USERNAME={{ op://taisce-secrets/lakekeeper-postgres/username }}
LAKEKEEPER_DB_PASSWORD={{ op://taisce-secrets/lakekeeper-postgres/password }}

# Encryption
LAKEKEEPER_ENCRYPTION_KEY={{ op://taisce-secrets/lakekeeper-auth/encryption_key }}

# MinIO
MINIO_ROOT_USER={{ op://taisce-secrets/lakekeeper-minio/username }}
MINIO_ROOT_PASSWORD={{ op://taisce-secrets/lakekeeper-minio/password }}
