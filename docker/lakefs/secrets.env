# =============================================================================
# LAKEFS - Locket Secrets Template
# =============================================================================

# PostgreSQL
LAKEFS_DB_USERNAME={{ op://taisce-secrets/lakefs-postgres/username }}
LAKEFS_DB_PASSWORD={{ op://taisce-secrets/lakefs-postgres/password }}

# Authentication
LAKEFS_AUTH_ENCRYPT_SECRET_KEY={{ op://taisce-secrets/lakefs-auth/secret_key }}

# MinIO
MINIO_ROOT_USER={{ op://taisce-secrets/lakefs-minio/username }}
MINIO_ROOT_PASSWORD={{ op://taisce-secrets/lakefs-minio/password }}
