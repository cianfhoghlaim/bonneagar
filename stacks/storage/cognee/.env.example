# =============================================================================
# COGNEE - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# PostgreSQL Database
# =============================================================================
DB_PROVIDER=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=cognee
DB_USERNAME=cognee
DB_PASSWORD=devpassword

# =============================================================================
# Memgraph (Graph Database)
# =============================================================================
MEMGRAPH_USER=memgraph
MEMGRAPH_PASSWORD=devpassword

# =============================================================================
# Cognee Service
# =============================================================================
COGNEE_PORT=8001
COGNEE_DEBUG_PORT=5678
COGNEE_DEBUG=false
COGNEE_LOG_LEVEL=WARNING

# Graph Database
GRAPH_DATABASE_PROVIDER=memgraph
GRAPH_DATABASE_URL=bolt://memgraph:7687

# Vector Database
VECTOR_DATABASE_PROVIDER=lancedb
VECTOR_DATABASE_URL=/data/lancedb

# LLM Defaults
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# =============================================================================
# Cognee MCP (optional, use `docker compose --profile mcp up`)
# =============================================================================
COGNEE_MCP_PORT=8002

# =============================================================================
# Secrets (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# DB_PASSWORD=<strong-password>                    # Set via Locket/Infisical in production
# MEMGRAPH_PASSWORD=<strong-password>               # Set via Locket/Infisical in production
# LLM_API_KEY=sk-...                               # Set via Locket/Infisical in production
# EMBEDDING_API_KEY=sk-...                         # Set via Locket/Infisical in production