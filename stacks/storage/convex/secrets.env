# =============================================================================
# CONVEX - Locket Exec Mode Secrets Template
# =============================================================================
# Used with: locket exec --env-file secrets.env -- docker compose up -d
# =============================================================================

# Instance secrets
CONVEX_INSTANCE_SECRET={{ infisical:///instance_secret }}

# S3/R2 storage (optional - for production file storage)
AWS_ACCESS_KEY_ID={{ infisical:///access_key_id }}
AWS_SECRET_ACCESS_KEY={{ infisical:///secret_access_key }}
AWS_ENDPOINT_URL={{ infisical:///endpoint_url }}

# Database URL (optional - for external database)
CONVEX_POSTGRES_URL={{ infisical:///connection_url }}
