# =============================================================================
# RISINGWAVE - Locket Secrets Template
# =============================================================================
# Replaces Confluent Kafka per the streaming refactor (Q1).
# RisingWave uses the PostgreSQL wire protocol (port 4566) and has its own
# user/role system. MinIO is the bundled S3 backing store.
# =============================================================================

# RisingWave internal admin + ETL users
RISINGWAVE_ADMIN_PASSWORD={{ infisical://dev-baile/risingwave/admin_password }}
RISINGWAVE_ETL_PASSWORD={{ infisical://dev-baile/risingwave/etl_password }}

# RisingWave's own Postgres backend (separate from the oideachais lakehouse)
RISINGWAVE_DATABASE_URL={{ infisical://dev-baile/risingwave/database_url }}

# MinIO backing store
RISINGWAVE_MINIO_USER={{ infisical://dev-baile/risingwave/minio_user }}
RISINGWAVE_MINIO_PASSWORD={{ infisical://dev-baile/risingwave/minio_password }}
