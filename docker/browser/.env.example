# =============================================================================
# BROWSER STACK - Development Environment Variables
# =============================================================================
# Copy to .env and fill in values for local development
# Production uses Locket for secrets injection
# =============================================================================

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# -----------------------------------------------------------------------------
# Service Ports
# -----------------------------------------------------------------------------
API_PORT=8003
STAGEHAND_PORT=3100
SKYVERN_PORT=8001
SKYVERN_UI_PORT=8080
GARAGE_S3_PORT=3900
GARAGE_WEB_PORT=3902

# -----------------------------------------------------------------------------
# Browser Configuration
# -----------------------------------------------------------------------------
DEFAULT_BACKEND=crawl4ai
FALLBACK_STRATEGY=cost
STAGEHAND_HEADLESS=true
STAGEHAND_MAX_SESSIONS=10
STAGEHAND_SESSION_TTL=300000
STAGEHAND_MODEL=glm-4.6
STAGEHAND_VISION_MODEL=glm-4.6v
STAGEHAND_AGENT_MODEL=google/gemini-3-flash-preview

# -----------------------------------------------------------------------------
# LLM Configuration
# -----------------------------------------------------------------------------
LLM_PROVIDER=anthropic

# LLM API Keys (fill in for development)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
ZAI_API_KEY=

# -----------------------------------------------------------------------------
# Paid Backend APIs (optional for development)
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
FIRECRAWL_API_KEY=

# -----------------------------------------------------------------------------
# Skyvern Database
# -----------------------------------------------------------------------------
SKYVERN_DB_PASSWORD=skyvern_dev

# -----------------------------------------------------------------------------
# Garage S3 Storage
# -----------------------------------------------------------------------------
GARAGE_RPC_SECRET=change_me_in_production
GARAGE_ADMIN_TOKEN=change_me_in_production

# -----------------------------------------------------------------------------
# Observability (optional)
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# -----------------------------------------------------------------------------
# 1Password Connect (for Locket sidecar)
# -----------------------------------------------------------------------------
OP_CONNECT_HOST=http://132.145.27.89:8080
OP_CONNECT_TOKEN_FILE=../../op_token
LOCKET_MODE=watch
