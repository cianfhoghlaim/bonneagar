# =============================================================================
# CRAWL4AI - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///<SECRET_KEY>).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - crawl4ai-llm: openai_api_key, deepseek_api_key, anthropic_api_key,
#       groq_api_key, together_api_key, mistral_api_key, gemini_api_token
# =============================================================================

# =============================================================================
# LLM Provider API Keys
# =============================================================================
OPENAI_API_KEY={{ infisical:///openai_api_key }}
DEEPSEEK_API_KEY={{ infisical:///deepseek_api_key }}
ANTHROPIC_API_KEY={{ infisical:///anthropic_api_key }}
GROQ_API_KEY={{ infisical:///groq_api_key }}
TOGETHER_API_KEY={{ infisical:///together_api_key }}
MISTRAL_API_KEY={{ infisical:///mistral_api_key }}
GEMINI_API_TOKEN={{ infisical:///gemini_api_token }}