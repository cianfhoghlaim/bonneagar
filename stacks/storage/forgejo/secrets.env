# =============================================================================
# FORGEJO - Secrets Template (Locket)
# =============================================================================
# These infisical:// references are resolved by Locket at runtime
# Vault: dev-baile

FORGEJO_DB_PASSWORD={{ infisical:///password }}
FORGEJO_SECRET_KEY={{ infisical:///secret-key }}
FORGEJO_INTERNAL_TOKEN={{ infisical:///internal-token }}

# PocketID OAuth2 (for SSO login)
POCKETID_CLIENT_ID={{ infisical:///client_id }}
POCKETID_CLIENT_SECRET={{ infisical:///client_secret }}
