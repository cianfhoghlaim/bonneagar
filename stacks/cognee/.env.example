# Cognee stack — Cianfhoghlaim Oideachais
# Copy to .env.local and fill in real values.
# Defaults work for local dev (with the lakehouse + litellm stacks already running).

# Cognee postgres password (used by both cognee and cognee-postgres)
COGNEE_POSTGRES_PASSWORD=devpassword

# LiteLLM master key — the cognee openai client sends this in the Authorization
# header. The litellm proxy then forwards it as the upstream API key. To avoid
# the upstream (DeepSeek) rejecting the litellm master key, compose.yaml sets
# LLM_API_KEY=no-key-needed and EMBEDDING_API_KEY=no-key-needed, forcing the
# proxy to use its own DEEPSEEK_API_KEY env var. So this value is only used by
# the dev compose.dev.yaml `env_file` (which doesn't override the hardcoded
# compose.yaml env vars).
LITELLM_API_KEY=sk-litellm-master-2026-xxx

# LanceDB API key (cognee writes embedding vectors to the lakehouse Lance namespace)
LANCEDB_API_KEY=devtoken

# Optional: LiteLLM model alias for entity extraction
# Default: "deepseek/deepseek-chat" (cost-effective, Irish-aware)
# Alternatives:
#   "extract"             # Gemini 2.5 Pro → GLM 4.6 → Gemini Flash (heavy, but blocked by API key issue)
#   "local/irish/uccix"   # Local GGUF (free, slower)
#   "openai/glm-4.6"      # Z.ai GLM 4.6
# COGNEE_LLM_MODEL=deepseek/deepseek-chat

# Optional: LiteLLM model alias for embeddings
# Default: "openai/text-embedding-3-small" (tiktoken-recognizable)
# COGNEE_EMBEDDING_MODEL=openai/text-embedding-3-small

# Runtime
ENVIRONMENT=production
LOG_LEVEL=INFO

# Auth (set both to true in production behind Pocket ID SSO)
REQUIRE_AUTHENTICATION=false
ENABLE_BACKEND_ACCESS_CONTROL=false
