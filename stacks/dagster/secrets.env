# =============================================================================
# DAGSTER UNIFIED - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical URI references (infisical:///secret_key).
#
# LOCKET USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml -f sidecar.yaml up -d
#
# INFISICAL ITEMS TO CREATE UNDER dev-baile:
#   dagster/  ducklake_postgres_password, garage_access_key, garage_secret_key,
#             anthropic_api_key, openai_api_key, langfuse_public_key, langfuse_secret_key
# =============================================================================

# DuckLake PostgreSQL (shared with lakehouse stack)
DUCKLAKE_POSTGRES_PASSWORD={{ infisical:///dagster/ducklake_postgres_password }}

# Garage S3 (shared with lakehouse stack)
AWS_ACCESS_KEY_ID={{ infisical:///dagster/garage_access_key }}
AWS_SECRET_ACCESS_KEY={{ infisical:///dagster/garage_secret_key }}

# LLM API Keys (reused from opencode + openai items in dev-baile)
ANTHROPIC_API_KEY={{ infisical:///anthropic/api_key }}
OPENAI_API_KEY={{ infisical:///openai/api_key }}

# Langfuse Observability
LANGFUSE_PUBLIC_KEY={{ infisical:///langfuse/public_key }}
LANGFUSE_SECRET_KEY={{ infisical:///langfuse/secret_key }}
