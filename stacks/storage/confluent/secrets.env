# =============================================================================
# CONFLUENT CLOUD - Environment Variables ($400 Credits)
# =============================================================================
# Credentials for Confluent Cloud Kafka cluster.
#
# CREDITS: $400 trial via CONFLUENTDEV1 code
# REGION: europe-west1 (GCP) - same region as other services
#
# GETTING STARTED:
# 1. Sign up at https://confluent.cloud with trial code: CONFLUENTDEV1
# 2. Create a Basic cluster in europe-west1 (GCP)
# 3. Create API keys for cluster access
# 4. Create Schema Registry API keys
# 5. Store keys in Infisical project
#
# IMPORTANT: Never commit actual credentials to version control.
# =============================================================================

# Kafka Cluster Configuration
CONFLUENT_BOOTSTRAP_SERVERS={{ infisical:///bootstrap_servers }}

# Kafka API Credentials
CONFLUENT_API_KEY={{ infisical:///api_key }}
CONFLUENT_API_SECRET={{ infisical:///api_secret }}

# Schema Registry Configuration
CONFLUENT_SCHEMA_REGISTRY_URL={{ infisical:///schema_registry_url }}
CONFLUENT_SR_API_KEY={{ infisical:///sr_api_key }}
CONFLUENT_SR_API_SECRET={{ infisical:///sr_api_secret }}

# ksqlDB Configuration (for streaming SQL)
CONFLUENT_KSQLDB_URL={{ infisical:///ksqldb_url }}
CONFLUENT_KSQLDB_API_KEY={{ infisical:///ksqldb_api_key }}
CONFLUENT_KSQLDB_API_SECRET={{ infisical:///ksqldb_api_secret }}

# =============================================================================
# Topic Configuration - Celtic Education Platform
# =============================================================================
# Naming convention: {domain}.{entity}.{action}
#
# OIDEACHAIS PIPELINE:
#   curriculum.ingested       - Raw curriculum document events
#   curriculum.embedded       - Embedding completion events
#   curriculum.translated     - Translation completion events
#   curriculum.evaluated      - Ragas quality metrics
#   exams.parsed              - SEC exam paper parsing events
#   exams.analyzed            - Exam analysis completion
#   agent.queries             - User query events
#   agent.responses           - Agent response events
#   graph.updates             - Knowledge graph CDC events
#
# CRYPTEOLAS PIPELINE:
#   defi.protocols            - DeFi protocol data events
#   defi.transactions         - Transaction analysis events
#   code.indexed              - Code indexing events
#   code.embedded             - Code embedding events
#
# TUATH PIPELINE:
#   game.events               - Game event stream
#   mythology.updates         - Mythology content updates
#   assets.generated          - Asset generation events
#
# SHARED:
#   metrics.observability     - Datadog/Langfuse metrics
#   errors.dlq                - Dead letter queue for failed events
# =============================================================================

# Topic prefixes for each pipeline
KAFKA_TOPIC_PREFIX_OIDEACHAIS=edu
KAFKA_TOPIC_PREFIX_CRYPTEOLAS=crypto
KAFKA_TOPIC_PREFIX_TUATH=game
