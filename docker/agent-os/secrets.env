# =============================================================================
# AGENT-OS SECRETS
# =============================================================================
# Template for AgentOS secrets. Use with locket for production.
#
# USAGE:
#   locket exec --env-file secrets.env -- docker compose up -d
#
# 1PASSWORD REFERENCES:
#   op://dev-baile/openai/credential
#   op://dev-baile/anthropic/credential
#   op://dev-baile/langfuse/public_key
#   op://dev-baile/langfuse/secret_key
#   op://dev-baile/x402-payment/pay_to_address
#   op://dev-baile/browserbase/api_key
#   op://dev-baile/browserbase/project_id
# =============================================================================

# -----------------------------------------------------------------------------
# AI Model API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=op://dev-baile/openai/credential
ANTHROPIC_API_KEY=op://dev-baile/anthropic/credential

# Model Configuration
AGNO_DEFAULT_MODEL=gpt-4o
AGNO_CLAUDE_MODEL=claude-sonnet-4-20250514

# -----------------------------------------------------------------------------
# Service Authentication
# -----------------------------------------------------------------------------
# Shared secret for A2A service-to-service JWT signing
AGENT_OS_SECRET_KEY=op://dev-baile/agent-os/secret_key

# -----------------------------------------------------------------------------
# x402 Payment (Crypteolas only)
# -----------------------------------------------------------------------------
X402_ENABLED=true
X402_PAY_TO_ADDRESS=op://dev-baile/x402-payment/pay_to_address
X402_NETWORK=base
X402_SKIP_VERIFICATION=false

# -----------------------------------------------------------------------------
# Browser Backends
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY=op://dev-baile/browserbase/api_key
BROWSERBASE_PROJECT_ID=op://dev-baile/browserbase/project_id
STAGEHAND_ENABLED=true
CRAWL4AI_ENABLED=true
SKYVERN_API_URL=
SKYVERN_API_KEY=

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY=op://dev-baile/langfuse/public_key
LANGFUSE_SECRET_KEY=op://dev-baile/langfuse/secret_key
LANGFUSE_HOST=https://langfuse.cianfhoghlaim.ie
AGNO_DEBUG=false

# -----------------------------------------------------------------------------
# Database URLs (optional, defaults to SQLite)
# -----------------------------------------------------------------------------
# OIDEACHAIS_DB_URL=postgresql://...
# CRYPTEOLAS_DB_URL=postgresql://...
# BROWSER_DB_URL=postgresql://...
# ALEYUM_DB_URL=postgresql://...

# -----------------------------------------------------------------------------
# Port Configuration
# -----------------------------------------------------------------------------
OIDEACHAIS_PORT=7772
CRYPTEOLAS_PORT=7771
BROWSER_PORT=7773
ALEYUM_PORT=7774
