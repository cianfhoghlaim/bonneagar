# Pydantic AI Gateway Configuration
# Unified LLM access with single API key, cost tracking, and BYOK support
# Docs: https://ai.pydantic.dev/gateway/

PYDANTIC_AI_GATEWAY_API_KEY={{ infisical:///api_key }}

# Gateway base URL (default: managed service)
PYDANTIC_GATEWAY_URL=https://gateway.pydantic.dev

# For Claude Code integration
ANTHROPIC_BASE_URL=https://gateway.pydantic.dev/proxy/anthropic
ANTHROPIC_AUTH_TOKEN={{ infisical:///api_key }}
