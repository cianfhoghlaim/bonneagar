# =============================================================================
# LOCKET ENVIRONMENT CONFIGURATION
# =============================================================================
# Generated by Ansible - Do not edit manually
# Template: locket.env.j2
#
# Source this file or use with systemd EnvironmentFile directive
# =============================================================================

# Secrets Provider
SECRETS_PROVIDER={{ locket_provider }}

{% if locket_provider == 'op-connect' %}
# -----------------------------------------------------------------------------
# 1PASSWORD CONNECT
# -----------------------------------------------------------------------------
{% if locket_op_connect_host %}
OP_CONNECT_HOST={{ locket_op_connect_host }}
{% endif %}
OP_CONNECT_TOKEN_FILE={{ locket_op_token_file }}

{% elif locket_provider == 'op' %}
# -----------------------------------------------------------------------------
# 1PASSWORD SERVICE ACCOUNT
# -----------------------------------------------------------------------------
OP_SERVICE_ACCOUNT_TOKEN_FILE={{ locket_op_token_file }}

{% elif locket_provider == 'bws' %}
# -----------------------------------------------------------------------------
# BITWARDEN SECRETS MANAGER
# -----------------------------------------------------------------------------
BWS_API_URL={{ locket_bws_api_url }}
BWS_IDENTITY_URL={{ locket_bws_identity_url }}
BWS_MACHINE_TOKEN_FILE={{ locket_op_token_file }}

{% endif %}
