{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "assignees": ["cliste"],
  "labels": ["renovate", "dependencies"],
  "docker-compose": {
    "fileMatch": ["**/compose.yaml"],
    "pinDigests": true
  },
  "packageRules": [
    {
      "description": "Group all Docker image updates together",
      "matchManagers": ["docker-compose"],
      "groupName": "docker images"
    },
    {
      "description": "Auto-merge patch updates for well-tested images",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["patch"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Schedule database updates on weekends only",
      "matchPackagePatterns": ["postgres", "redis", "mysql", "mariadb"],
      "schedule": ["after 10am on saturday"]
    },
    {
      "description": "Pin major versions, only update minors automatically",
      "matchManagers": ["docker-compose"],
      "matchUpdateTypes": ["major"],
      "labels": ["major-update"],
      "automerge": false
    },
    {
      "description": "Group sruth-shared updates and auto-merge patches",
      "matchPackageNames": ["sruth-shared"],
      "groupName": "sruth-shared",
      "labels": ["sruth", "python"],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Group all Python dependencies from sruth flows",
      "matchManagers": ["pip_requirements", "pip_setup", "poetry", "pep621"],
      "matchFileNames": ["sruth/**/pyproject.toml", "sruth/**/requirements*.txt"],
      "groupName": "sruth python dependencies"
    }
  ],
  "schedule": ["after 4am and before 7am every weekday"],
  "timezone": "Europe/Dublin"
}
