# =============================================================================
# LAKEHOUSE - Locket Secrets Template
# =============================================================================
# All values are Locket-canonical `infisical://dev-baile/<svc>/<key>` URIs
# resolved at container start by the Locket sidecar (see sidecar.yaml).
# Migrated from the legacy Jinja `{{ infisical:///... }}` form by the
# `consolidate-observability-and-graph` openspec change (2026-06-26).
# Updated for the `centralise-data-plane` rewrite (2026-07-30): added
# POSTGRES_PASSWORD + CLICKHOUSE_PASSWORD + REDIS_PASSWORD + the 4 new
# Garage service buckets are auto-created by the updated garage-init.
# =============================================================================

# =============================================================================
# PlanetScale PostgreSQL (OPTIONAL override for managed deployments)
# =============================================================================
# PLANETSCALE_DATABASE_URL is now an OVERRIDE only — when unset, Lakekeeper
# uses the centralised lakehouse-postgres container (the recommended path
# for both dev and prod on bunchloch).
# Connection URL format: postgresql://user:password@host:port/database?sslmode=require
PLANETSCALE_DATABASE_URL=infisical://dev-baile/lakehouse/database_url

# =============================================================================
# Centralised Postgres (lakehouse-postgres) — 12 databases
# =============================================================================
# Superuser password (the existing `lakekeeper` user). Used by:
#   - Lakekeeper (ducklake_* databases)
#   - Dagster (dagster_local database)
#   - Olake (olake_state database)
#   - Nimtable (nimtable database)
#   - langfuse (lakehouse.langfuse database) — auth via DATABASE_URL
#   - mlflow (lakehouse.mlflow database) — auth via MLFLOW_BACKEND_STORE_URI
#   - litellm (lakehouse.litellm database) — auth via DATABASE_URL
POSTGRES_USER=infisical://dev-baile/lakehouse/postgres_user
POSTGRES_PASSWORD=infisical://dev-baile/lakehouse/postgres_password
POSTGRES_DB=infisical://dev-baile/lakehouse/postgres_db

# =============================================================================
# Lakekeeper Configuration
# =============================================================================
# 64-character hex encryption key for Lakekeeper secrets storage
LAKEKEEPER_ENCRYPTION_KEY=infisical://dev-baile/lakehouse/encryption_key

# SSL mode for the lakehouse-postgres connection (should be 'prefer' for
# local dev, 'require' for managed Postgres)
LAKEKEEPER_SSL_MODE=prefer

# =============================================================================
# Garage S3 Storage
# =============================================================================
# RPC secret for internal Garage communication (64+ char random string)
GARAGE_RPC_SECRET=infisical://dev-baile/lakehouse/rpc_secret

# Admin API token for Garage management
GARAGE_ADMIN_TOKEN=infisical://dev-baile/lakehouse/admin_token

# S3 access credentials
GARAGE_ACCESS_KEY_ID=infisical://dev-baile/lakehouse/access_key_id
GARAGE_SECRET_ACCESS_KEY=infisical://dev-baile/lakehouse/secret_access_key

# =============================================================================
# Lance Namespace Sidecar (Optional)
# =============================================================================
# Auth token for Lakekeeper (if authentication is enabled)
# LANCE_ICEBERG_AUTH_TOKEN=infisical://dev-baile/lakehouse/service_token

# =============================================================================
# Cloudflare R2 (Remote Object Storage)
# =============================================================================
# S3-compatible cloud storage for production deployments
R2_ACCESS_KEY_ID=infisical://dev-baile/lakehouse/access_key_id
R2_SECRET_ACCESS_KEY=infisical://dev-baile/lakehouse/secret_access_key
R2_ACCOUNT_ID=infisical://dev-baile/lakehouse/account_id
R2_BUCKET_NAME=lakehouse

# =============================================================================
# MotherDuck (Remote Query Engine)
# =============================================================================
# Cloud-hosted DuckDB for production analytics
MOTHERDUCK_TOKEN=infisical://dev-baile/lakehouse/token

# =============================================================================
# Nimtable Iceberg Catalog UI (extend-lakehouse-with-nimtable-olake-lancedb)
# =============================================================================
# JDBC password for the Spring Boot DataSource
NIMTABLE_JDBC_PASSWORD=infisical://dev-baile/lakehouse/jdbc_password
# Dashboard secret (CSRF token)
NIMTABLE_DASHBOARD_SECRET=infisical://dev-baile/lakehouse/dashboard_secret

# =============================================================================
# Olake CDC Engine (extend-lakehouse-with-nimtable-olake-lancedb)
# =============================================================================
# JDBC password for the olake_state database
OLAKE_JDBC_PASSWORD=infisical://dev-baile/lakehouse/jdbc_password
# Source Postgres password (the DB being replicated FROM)
OLAKE_SOURCE_PG_PASSWORD=infisical://dev-baile/lakehouse/source_pg_password
# Iceberg writer S3 secret key (for writing to Garage)
OLAKE_WRITER_S3_SECRET_KEY=infisical://dev-baile/lakehouse/writer_s3_secret_key

# =============================================================================
# LanceDB Viewer (extend-lakehouse-with-nimtable-olake-lancedb)
# =============================================================================
# Admin token for the LanceDB viewer
LANCEDB_VIEWER_ADMIN_TOKEN=infisical://dev-baile/lakehouse/lancedb_viewer_admin_token

# =============================================================================
# ClickHouse (Centralised Columnar Engine — added 2026-07, centralise-data-plane)
# =============================================================================
# Consumed by the langfuse stack for trace analytics + batch export.
CLICKHOUSE_USER=infisical://dev-baile/lakehouse-clickhouse/user
CLICKHOUSE_PASSWORD=infisical://dev-baile/lakehouse-clickhouse/password
CLICKHOUSE_DB=infisical://dev-baile/lakehouse-clickhouse/db

# =============================================================================
# Redis (Centralised Queue/Cache — added 2026-07, centralise-data-plane)
# =============================================================================
# Consumed by the langfuse stack for ingestion queue + cache.
REDIS_PASSWORD=infisical://dev-baile/lakehouse-redis/password
REDIS_MAXMEMORY_POLICY=allkeys-lru
