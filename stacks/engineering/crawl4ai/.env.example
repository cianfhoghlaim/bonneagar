# =============================================================================
# CRAWL4AI - Local Development Environment
# =============================================================================
# Copy this file to .env.local and edit values as needed.
# For production, secrets come from Locket/Infisical via sidecar.yaml.
#
# Usage: cp .env.example .env.local

# =============================================================================
# Crawl4AI Service
# =============================================================================
IMAGE=unclecode/crawl4ai:latest
TAG=latest
INSTALL_TYPE=default
ENABLE_GPU=false
LLM_PROVIDER=

# =============================================================================
# LLM Provider API Keys (set in .env.local for dev, or via Locket/Infisical in production)
# =============================================================================
# OPENAI_API_KEY=sk-...                     # Set via Locket/Infisical in production
# DEEPSEEK_API_KEY=sk-...                   # Set via Locket/Infisical in production
# ANTHROPIC_API_KEY=sk-ant-...              # Set via Locket/Infisical in production
# GROQ_API_KEY=gsk_...                      # Set via Locket/Infisical in production
# TOGETHER_API_KEY=...                      # Set via Locket/Infisical in production
# MISTRAL_API_KEY=...                       # Set via Locket/Infisical in production
# GEMINI_API_TOKEN=...                      # Set via Locket/Infisical in production