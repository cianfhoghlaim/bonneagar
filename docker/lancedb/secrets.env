# =============================================================================
# LANCEDB - Locket Secrets Template
# =============================================================================

# S3/R2 Credentials (for self-hosted storage profile)
AWS_ACCESS_KEY_ID={{ op://taisce-secrets/cloudflare-r2/access_key_id }}
AWS_SECRET_ACCESS_KEY={{ op://taisce-secrets/cloudflare-r2/secret_access_key }}
AWS_ENDPOINT_URL={{ op://taisce-secrets/cloudflare-r2/endpoint_url }}

# =============================================================================
# LanceDB Cloud ($100 credits)
# =============================================================================
# Credentials stored in 1Password: taisce-secrets/lancedb-cloud
#
# API Key format: sk_...
# Connection: db://project/database or use API key directly
# =============================================================================

LANCEDB_API_KEY={{ op://dev-baile/lancedb-cloud/api_key }}
LANCEDB_REGION=us-east-1

# Toggle cloud vs local (set to true when ready to migrate)
LANCEDB_USE_CLOUD=true
