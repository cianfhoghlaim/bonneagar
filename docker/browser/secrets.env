# =============================================================================
# BROWSER STACK - Secrets Template (Locket)
# =============================================================================
# These op:// references are resolved by Locket at runtime from 1Password
# Vault: dev-baile
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY={{ op://dev-baile/anthropic/api-key }}
OPENAI_API_KEY={{ op://dev-baile/openai/api-key }}
GOOGLE_API_KEY={{ op://dev-baile/google-ai/api-key }}
ZAI_API_KEY={{ op://dev-baile/zhipu-ai/api-key }}

# -----------------------------------------------------------------------------
# Paid Browser Backend APIs
# -----------------------------------------------------------------------------
BROWSERBASE_API_KEY={{ op://dev-baile/browserbase/api-key }}
BROWSERBASE_PROJECT_ID={{ op://dev-baile/browserbase/project-id }}
FIRECRAWL_API_KEY={{ op://dev-baile/firecrawl/api-key }}

# -----------------------------------------------------------------------------
# Skyvern Database
# -----------------------------------------------------------------------------
SKYVERN_DB_PASSWORD={{ op://dev-baile/browser-skyvern-db/password }}

# -----------------------------------------------------------------------------
# Garage S3 Storage
# -----------------------------------------------------------------------------
GARAGE_RPC_SECRET={{ op://dev-baile/browser-garage/rpc-secret }}
GARAGE_ADMIN_TOKEN={{ op://dev-baile/browser-garage/admin-token }}

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
LANGFUSE_PUBLIC_KEY={{ op://dev-baile/langfuse/public-key }}
LANGFUSE_SECRET_KEY={{ op://dev-baile/langfuse/secret-key }}
