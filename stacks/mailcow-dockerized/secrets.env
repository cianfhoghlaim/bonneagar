# =============================================================================
# MAILCOW-DOCKERIZED - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///secret_key).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - mailcow-db: dbuser, dbname, dbpass, dbroot
#   - mailcow-redis: redispass, redismasterpass
#   - mailcow-api: api_key, api_key_read_only, api_allow_from
#   - mailcow-acme: acme_contact
#   - mailcow-dovecot: dovecot_master_user, dovecot_master_pass
#   - mailcow-mailcow: mailcow_hostname
#   - mailcow-spamhaus: spamhaus_dqs_key
# =============================================================================

# =============================================================================
# Database (MySQL / MariaDB)
# =============================================================================
DBNAME={{ infisical:///dbname }}
DBUSER={{ infisical:///dbuser }}
DBPASS={{ infisical:///dbpass }}
DBROOT={{ infisical:///dbroot }}

# =============================================================================
# Redis
# =============================================================================
REDISPASS={{ infisical:///redispass }}
REDISMASTERPASS={{ infisical:///redismasterpass }}

# =============================================================================
# Mailcow Hostname & Identity
# =============================================================================
MAILCOW_HOSTNAME={{ infisical:///mailcow_hostname }}

# =============================================================================
# API Keys
# =============================================================================
API_KEY={{ infisical:///api_key }}
API_KEY_READ_ONLY={{ infisical:///api_key_read_only }}
API_ALLOW_FROM={{ infisical:///api_allow_from }}

# =============================================================================
# ACME / Let's Encrypt
# =============================================================================
ACME_CONTACT={{ infisical:///acme_contact }}

# =============================================================================
# Dovecot Master Credentials
# =============================================================================
DOVECOT_MASTER_USER={{ infisical:///dovecot_master_user }}
DOVECOT_MASTER_PASS={{ infisical:///dovecot_master_pass }}

# =============================================================================
# Spamhaus DQS Key
# =============================================================================
SPAMHAUS_DQS_KEY={{ infisical:///spamhaus_dqs_key }}

# =============================================================================
# Configuration (non-secret, set as needed)
# =============================================================================
TZ=Europe/Dublin
MAILCOW_PASS_SCHEME=BLF-CRYPT
COMPOSE_PROJECT_NAME=mailcow-dockerized
IPV4_NETWORK=172.22.1
IPV6_NETWORK=fd4d:6169:6c63:6f77::/64
SQL_PORT=127.0.0.1:13306
REDIS_PORT=127.0.0.1:7654
HTTPS_PORT=443
HTTP_PORT=80
SMTP_PORT=25
SMTPS_PORT=465
SUBMISSION_PORT=587
IMAP_PORT=143
IMAPS_PORT=993
POP_PORT=110
POPS_PORT=995
SIEVE_PORT=4190