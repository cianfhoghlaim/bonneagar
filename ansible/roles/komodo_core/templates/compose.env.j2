####################################
# KOMODO COMPOSE - VARIABLES
####################################
# Deployed by Ansible komodo_core role
# Host: {{ komodo_host }}
####################################

## Image tag
COMPOSE_KOMODO_IMAGE_TAG={{ komodo_core_image_tag }}

## Backups path
COMPOSE_KOMODO_BACKUPS_PATH=./backups

## DB credentials (fetched from Infisical)
KOMODO_DATABASE_USERNAME={{ komodo_database_username }}
KOMODO_DATABASE_PASSWORD={{ komodo_database_password }}

## MongoDB initialization (same values as above)
MONGO_INITDB_ROOT_USERNAME={{ komodo_database_username }}
MONGO_INITDB_ROOT_PASSWORD={{ komodo_database_password }}

## Core/Periphery passkey (fetched from Infisical)
KOMODO_PASSKEY={{ komodo_passkey }}

## Timezone
TZ={{ komodo_timezone }}

#=-------------------------=#
#= Komodo Core Environment =#
#=-------------------------=#

## Dashboard URL
KOMODO_HOST={{ komodo_host }}

## Dashboard title
KOMODO_TITLE={{ komodo_title }}

## First server configuration
KOMODO_FIRST_SERVER={{ komodo_first_server }}
KOMODO_FIRST_SERVER_NAME={{ komodo_first_server_name }}

## UI options
KOMODO_DISABLE_CONFIRM_DIALOG={{ komodo_disable_confirm_dialog | lower }}
KOMODO_TRANSPARENT_MODE={{ komodo_transparent_mode | lower }}

## Monitoring intervals
KOMODO_MONITORING_INTERVAL="{{ komodo_monitoring_interval }}"
KOMODO_RESOURCE_POLL_INTERVAL="{{ komodo_resource_poll_interval }}"

## Security
KOMODO_WEBHOOK_SECRET={{ komodo_webhook_secret }}
KOMODO_JWT_SECRET={{ komodo_jwt_secret }}
KOMODO_JWT_TTL="{{ komodo_jwt_ttl }}"

## Authentication
KOMODO_LOCAL_AUTH={{ komodo_local_auth | lower }}
KOMODO_INIT_ADMIN_USERNAME={{ komodo_init_admin_username }}
KOMODO_INIT_ADMIN_PASSWORD={{ komodo_init_admin_password }}
KOMODO_DISABLE_USER_REGISTRATION={{ komodo_disable_user_registration | lower }}
KOMODO_ENABLE_NEW_USERS={{ komodo_enable_new_users | lower }}
KOMODO_DISABLE_NON_ADMIN_CREATE={{ komodo_disable_non_admin_create | lower }}

## Logging
KOMODO_LOGGING_PRETTY={{ komodo_logging_pretty | lower }}
KOMODO_PRETTY_STARTUP_CONFIG={{ komodo_pretty_startup_config | lower }}

## OIDC Login (disabled by default)
KOMODO_OIDC_ENABLED=false

## Github Oauth (disabled by default)
KOMODO_GITHUB_OAUTH_ENABLED=false

## Google Oauth (disabled by default)
KOMODO_GOOGLE_OAUTH_ENABLED=false

#=------------------------------=#
#= Komodo Periphery Environment =#
#=------------------------------=#

## Periphery root directory
PERIPHERY_ROOT_DIRECTORY={{ komodo_periphery_root }}

## Periphery passkeys (must include KOMODO_PASSKEY)
PERIPHERY_PASSKEYS=${KOMODO_PASSKEY}

## SSL for periphery
PERIPHERY_SSL_ENABLED={{ komodo_periphery_ssl_enabled | lower }}

## Terminals
PERIPHERY_DISABLE_TERMINALS={{ komodo_periphery_disable_terminals | lower }}

## Disk mount filtering
PERIPHERY_INCLUDE_DISK_MOUNTS={{ komodo_periphery_include_disk_mounts }}

## Logging
PERIPHERY_LOGGING_PRETTY={{ komodo_logging_pretty | lower }}
PERIPHERY_PRETTY_STARTUP_CONFIG={{ komodo_pretty_startup_config | lower }}
