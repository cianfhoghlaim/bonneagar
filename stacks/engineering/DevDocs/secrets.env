# =============================================================================
# DEVDOCS - Locket Secrets Template
# =============================================================================
# Template file for Locket secret injection.
# Uses Infisical references (infisical:///<SECRET_KEY>).
#
# USAGE:
#   locket exec --provider infisical \
#     --connect.host http://132.145.27.89:8080 \
#     --connect.token-file /path/to/token \
#     --env-file secrets.env \
#     -- docker compose -f compose.yaml up -d
#
# INFISICAL SECRETS TO CREATE:
#   - devdocs-frontend: next_public_backend_url
#   - devdocs-crawl4ai: crawl4ai_api_token
# =============================================================================

# =============================================================================
# Frontend
# =============================================================================
NEXT_PUBLIC_BACKEND_URL={{ infisical:///next_public_backend_url }}

# =============================================================================
# Crawl4AI API Token (shared by backend and crawl4ai service)
# =============================================================================
CRAWL4AI_API_TOKEN={{ infisical:///crawl4ai_api_token }}